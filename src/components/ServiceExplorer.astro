---
import { SITE_DATA } from '../constants/siteData';

interface Props {
  services: typeof SITE_DATA.services;
}

const { services } = Astro.props;
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="flex flex-col lg:flex-row gap-8 lg:gap-16 items-start overflow-hidden lg:overflow-visible">
    
    <!-- Sidebar Navigation (Desktop) -->
    <div class="w-full lg:w-1/3 lg:sticky lg:top-32 space-y-2 z-20">
      <div class="mb-4 lg:mb-8">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-accent mb-2 block"> Our Capabilities </span>
        <h2 class="font-serif text-3xl font-bold text-brand-blue mb-4 leading-tight">Expertise Areas</h2>
        <div class="w-16 h-1 bg-brand-accent rounded-full mb-6 lg:mb-0"></div>
      </div>
      
      <div class="flex flex-row lg:flex-col lg:space-y-1 overflow-x-auto lg:overflow-x-visible no-scrollbar pb-4 lg:pb-0 gap-3 lg:gap-1" id="service-nav">
        {services.map((service, index) => (
          <button 
            class={`service-tab-btn group flex items-center justify-between px-5 py-3.5 lg:px-6 lg:py-4 rounded-xl text-left transition-all duration-300 border-l-4 whitespace-nowrap lg:whitespace-normal cursor-pointer ${index === 0 ? 'active bg-white border-brand-accent shadow-md text-brand-blue' : 'border-transparent text-slate-500 hover:text-brand-blue hover:bg-white hover:shadow-sm'}`}
            data-index={index}
          >
            <span class="font-bold text-[14px] lg:text-[15px] uppercase tracking-wide group-hover:pl-1 transition-all duration-300">{service.category}</span>
            <svg class={`hidden lg:block w-5 h-5 transition-transform duration-300 ${index === 0 ? 'translate-x-0 opacity-100' : '-translate-x-2 opacity-0 group-hover:translate-x-0 group-hover:opacity-100'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </button>
        ))}
      </div>
    </div>

    <!-- Main Content Area -->
    <div class="w-full lg:w-2/3 lg:min-h-[500px] relative">
      <div id="service-content-container" class="relative transition-all duration-500">
        {services.map((service, index) => (
          <div 
            class={`service-content-pane lg:absolute top-0 left-0 w-full transition-all duration-500 ${index === 0 ? 'active opacity-100 translate-y-0 relative z-10' : 'opacity-0 translate-y-10 pointer-events-none absolute invisible z-0'}`}
            id={`pane-${index}`}
            data-pane-index={index}
          >
            <div class="bg-white/80 backdrop-blur-xl rounded-2xl md:rounded-3xl p-6 md:p-12 border border-white/50 shadow-2xl relative overflow-hidden group">
              <!-- Background Accent -->
              <div class="absolute -right-20 -top-20 w-64 h-64 bg-brand-accent/5 rounded-full blur-3xl group-hover:bg-brand-accent/10 transition-colors duration-500"></div>
              
              <div class="relative z-10 w-full">
                <div class="flex items-center space-x-6 mb-8 md:mb-10">
                  <div class="w-14 h-14 md:w-20 md:h-20 rounded-2xl bg-brand-light flex items-center justify-center shadow-inner group-hover:bg-brand-blue group-hover:scale-105 transition-all duration-500">
                    <svg class="w-8 h-8 md:w-10 md:h-10 text-brand-accent group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <h3 class="text-2xl md:text-4xl font-serif font-bold text-brand-blue leading-snug">
                    {service.category}
                  </h3>
                </div>
                
                <div class="w-full h-px bg-slate-100 mb-8 md:mb-10 opacity-50"></div>
                
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-7">
                  {service.items.map(item => (
                    <li class="flex items-start text-[15px] md:text-[17px] text-slate-600 leading-relaxed group/item animate-fadeIn">
                      <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-accent/10 flex items-center justify-center mr-4 mt-0.5 group-hover/item:bg-brand-accent group-hover/item:text-white transition-all duration-300">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                        </svg>
                      </span>
                      <span class="group-hover/item:text-slate-900 transition-colors">{item}</span>
                    </li>
                  ))}
                </ul>

                <div class="mt-12 md:mt-20 pt-10 border-t border-slate-100 flex flex-col sm:flex-row gap-4">
                  <a href="/contact" class="px-8 py-4 bg-brand-blue text-white font-bold rounded-sm hover:bg-brand-blue-dark transition-all shadow-xl flex items-center justify-center">
                    Let's Discuss {service.category.split(' ')[0]}
                    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </a>
                  <a href="mailto:jaisal@csjdm.com" class="px-8 py-4 bg-white text-brand-blue font-bold rounded-sm border border-slate-200 hover:border-brand-accent hover:text-brand-accent transition-all text-center">
                    Get Expert Advice
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  function setupTabs() {
    const buttons = document.querySelectorAll('.service-tab-btn');
    const panes = document.querySelectorAll('.service-content-pane');
    const contentArea = document.getElementById('service-content-container');

    if (!contentArea) return;

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const index = btn.getAttribute('data-index');
        
        // Update Buttons
        buttons.forEach(b => {
          b.classList.remove('active', 'bg-white', 'border-brand-accent', 'shadow-md', 'text-brand-blue');
          b.classList.add('border-transparent', 'text-slate-500');
          const svg = b.querySelector('svg');
          if (svg) svg.classList.add('-translate-x-2', 'opacity-0');
        });
        btn.classList.add('active', 'bg-white', 'border-brand-accent', 'shadow-md', 'text-brand-blue');
        btn.classList.remove('border-transparent', 'text-slate-500');
        const activeSvg = btn.querySelector('svg');
        if (activeSvg) activeSvg.classList.remove('-translate-x-2', 'opacity-0');

        // Update Content Panes
        panes.forEach((pane, i) => {
          if (i.toString() === index) {
            pane.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none', 'absolute', 'invisible', 'z-0');
            pane.classList.add('active', 'opacity-100', 'translate-y-0', 'relative', 'z-10');
          } else {
            pane.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none', 'absolute', 'invisible', 'z-0');
            pane.classList.remove('active', 'opacity-100', 'translate-y-0', 'relative', 'z-10');
          }
        });
        
        // Smooth scroll to container only on mobile if pane top is out of view
        if (window.innerWidth < 1024) {
          const rect = contentArea.getBoundingClientRect();
          if (rect.top < 80) { // If it's already past the sticky header height
            window.scrollTo({
              top: window.scrollY + rect.top - 100,
              behavior: 'smooth'
            });
          }
        }
      });
    });
  }

  // Run on first load
  setupTabs();
  // Run on view transitions if active
  document.addEventListener('astro:after-swap', setupTabs);
</script>

<style>
  .service-tab-btn {
    cursor: pointer;
  }
  
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Fade-in for list items on tab change */
  .active ul > li {
    animation: fadeInItem 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  @keyframes fadeInItem {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* Delay list items animation */
  .active ul > li:nth-child(1) { animation-delay: 0.1s; }
  .active ul > li:nth-child(2) { animation-delay: 0.15s; }
  .active ul > li:nth-child(3) { animation-delay: 0.2s; }
  .active ul > li:nth-child(4) { animation-delay: 0.25s; }
  .active ul > li:nth-child(5) { animation-delay: 0.3s; }
  .active ul > li:nth-child(n+6) { animation-delay: 0.35s; }
</style>
