---
interface Props {
  variant?: 'light' | 'dark';
  className?: string;
}

const { 
  variant = 'dark', 
  className = '' 
} = Astro.props;
---

<div class={`flex items-center ${className}`}>
  <a href="/" class="block">
    <img 
      src="/images/logo.png" 
      alt="JDM And Associates LLP - Company Secretaries & Corporate Consultants" 
      class={`h-8 sm:h-10 lg:h-12 xl:h-14 w-auto object-contain ${variant === 'light' ? 'brightness-0 invert' : ''}`}
      loading="eager"
      decoding="async"
    />
  </a>
</div>
