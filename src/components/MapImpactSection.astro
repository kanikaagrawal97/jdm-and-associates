---
import IndiaMap from './IndiaMap.astro';
---

<section class="py-24 relative overflow-hidden bg-white border-t border-slate-100">
  
  <!-- Premium Background Details -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-brand-accent/5 via-transparent to-brand-blue/5 pointer-events-none"></div>
  <div class="absolute top-0 left-0 w-full h-full opacity-[0.02] pointer-events-none" style="background-image: radial-gradient(#1B5091 1px, transparent 1px); background-size: 32px 32px;"></div>
  
  <!-- Decorative Orbit around Map area -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-[600px] h-[600px] lg:w-[800px] lg:h-[800px] translate-x-1/4 rounded-full border border-brand-blue/5 animate-[spin_40s_linear_infinite] pointer-events-none z-0">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-brand-accent/20 rounded-full blur-[2px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
      
      <!-- Text Content -->
      <div class="w-full lg:w-1/2 animate-on-scroll slide-in-left">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-accent/10 border border-brand-accent/20 mb-6">
          <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"></span>
          <span class="text-brand-accent font-bold text-[10px] uppercase tracking-widest mt-0.5">National Presence</span>
        </span>
        
        <h2 class="font-serif text-4xl sm:text-5xl md:text-6xl font-bold text-brand-blue mb-8 leading-[1.1] tracking-tight">
          Delivering Impact <br/><span class="italic font-light text-slate-400">Across the Nation</span>
        </h2>
        
        <div class="grid grid-cols-2 gap-8 mb-10 border-l-[3px] border-brand-accent pl-6 py-2 bg-gradient-to-r from-brand-accent/5 to-transparent rounded-r-2xl">
          <div>
            <h3 class="text-5xl md:text-6xl font-black text-brand-blue tracking-tighter mb-1">
              <span class="count-up" data-count="10" data-suffix="+">10</span>
            </h3>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-2">Years of Excellence</p>
          </div>
          <div>
            <h3 class="text-5xl md:text-6xl font-black text-brand-blue tracking-tighter mb-1">
               <span class="count-up" data-count="500" data-suffix="+">500+</span>
            </h3>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-2">Clients Nationwide</p>
          </div>
        </div>

        <p class="text-slate-600 text-lg sm:text-xl leading-relaxed mb-6 font-medium">
          With decades of corporate advisory excellence and <strong class="text-brand-blue font-bold">hundreds of clients</strong> across India, we are a trusted strategic partner for businesses continuously navigating regulatory requirements.
        </p>
        
        <p class="text-slate-600 text-lg sm:text-xl leading-relaxed">
          The map highlights our expansive <strong class="text-brand-accent font-semibold">client footprint</strong> marking regions where we ensure precise governance, seamless compliance, and robust legal frameworks.
        </p>

        <!-- CTA Link -->
        <div class="mt-10">
          <a href="/contact" class="inline-flex items-center text-brand-blue font-black group hover:text-brand-accent transition-colors border-b-2 border-brand-blue hover:border-brand-accent pb-1 uppercase tracking-widest text-xs">
            Partner With Us
            <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>

      <!-- Map Content -->
      <div class="w-full lg:w-1/2 animate-on-scroll slide-in-right relative">
        <div class="relative w-full max-w-lg mx-auto">
          <!-- Multi-layered glowing backdrop -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-3/4 h-3/4 bg-brand-accent/15 blur-[100px] rounded-full -z-10 mix-blend-multiply transition-all duration-1000"></div>
          <div class="absolute top-1/4 right-1/4 w-1/2 h-1/2 bg-brand-blue/10 blur-[80px] rounded-full -z-10 mix-blend-multiply transition-all duration-1000"></div>
          
          <!-- The Map -->
          <div class="relative z-10 p-2 sm:p-6 transform hover:scale-[1.03] transition-transform duration-700 ease-out drop-shadow-2xl hover:drop-shadow-[0_35px_35px_rgba(30,58,138,0.15)] filter">
            <IndiaMap />
          </div>

          <!-- Premium Glassmorphism Floating Card -->
          <div class="absolute bottom-12 left-0 md:-left-12 bg-white/80 backdrop-blur-xl border border-white/40 shadow-[0_20px_40px_-5px_rgba(0,0,0,0.08)] rounded-3xl p-4 md:p-6 flex items-center gap-5 z-20 hover:scale-105 transition-all duration-500 float-card cursor-default group">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-blue/10 to-brand-blue/5 flex items-center justify-center shrink-0 relative overflow-hidden">
               <span class="absolute inset-0 rounded-2xl border-2 border-brand-blue animate-ping opacity-20"></span>
               <div class="absolute inset-0 bg-brand-blue/5 -rotate-12 group-hover:rotate-0 transition-transform duration-500"></div>
               <svg class="w-7 h-7 text-brand-blue relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
            </div>
            <div>
              <p class="text-3xl font-black text-brand-blue tracking-tighter leading-none mb-1 group-hover:text-brand-accent transition-colors duration-300">10</p>
              <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 whitespace-nowrap">Active Regions</p>
            </div>
          </div>
          
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes floatCard {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(1deg); }
  }
  .float-card {
    animation: floatCard 6s ease-in-out infinite;
  }
</style>
