---
import Logo from './Logo.astro';
import { SITE_DATA } from '../constants/siteData';

const pathname = Astro.url.pathname;
const isActive = (href) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};

const links = SITE_DATA.navLinks;
---

<header class="fixed top-0 w-full z-50 transition-all duration-300 glass" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Logo Group -->
      <div class="flex-shrink-0 flex items-center space-x-4 ">
        <img 
          src="/images/cs_logo.png" 
          alt="Company Secretary Logo" 
          class="h-12 w-auto opacity-90 mb-1"
        />
        <div class="h-8 w-px bg-brand-blue/10"></div>
        <Logo 
          variant="dark" 
          className="transform transition-transform duration-300 hover:scale-[1.02]"
        />
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8 items-center">
        {links.map(link => (
          link.name === 'Services' ? (
            <div class="relative group h-full flex items-center">
              <a
                href={link.href}
                class={`font-medium text-sm transition-colors flex items-center gap-1 py-8 ${
                  isActive(link.href) 
                    ? 'text-brand-accent border-b-2 border-brand-accent font-bold' 
                    : 'text-brand-blue hover:text-brand-accent'
                }`}
              >
                {link.name}
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              
              <!-- Dropdown Menu -->
              <div class="absolute top-[100%] left-0 w-72 bg-white shadow-2xl rounded-sm border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50 py-4">
                <div class="max-h-[70vh] overflow-y-auto custom-scrollbar">
                  {SITE_DATA.services.map(service => (
                    <a 
                      href={`/services#${service.slug}`}
                      class="block px-6 py-3 text-sm text-brand-blue hover:bg-slate-50 hover:text-brand-accent transition-colors border-l-2 border-transparent hover:border-brand-accent"
                    >
                      <span class="block font-semibold">{service.category}</span>
                    </a>
                  ))}
                  <div class="mt-2 px-6 pt-2 border-t border-slate-50">
                    <a href="/services" class="text-xs font-bold text-brand-accent uppercase tracking-widest hover:underline">View All Services →</a>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class={`font-medium text-sm transition-colors py-8 ${
                isActive(link.href) 
                  ? 'text-brand-accent border-b-2 border-brand-accent font-bold' 
                  : 'text-brand-blue hover:text-brand-accent'
              }`}
            >
              {link.name}
            </a>
          )
        ))}
        <a 
          href="/contact" 
          class="bg-brand-blue text-white hover:bg-brand-blue-dark px-5 py-2.5 rounded-sm transition-all duration-300 text-sm font-semibold shadow-md hover:shadow-lg transform hover:-translate-y-0.5"
        >
          Contact Us
        </a>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button
          type="button"
          id="mobile-menu-button"
          class="text-brand-blue hover:text-brand-accent focus:outline-none focus:ring-2 focus:ring-brand-accent p-2"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Icon: Menu -->
          <svg class="h-6 w-6 block" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Icon: Close -->
          <svg class="h-6 w-6 hidden" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>

</header>

<!-- Mobile Menu Overflow Background -->
<div class="md:hidden fixed inset-0 z-40 bg-slate-900/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300" id="mobile-menu-overlay"></div>

<!-- Mobile Menu Drawer -->
<div class="md:hidden fixed top-0 right-0 bottom-0 w-[85%] max-w-sm z-50 bg-white shadow-2xl transform transition-transform duration-500 translate-x-full overflow-y-auto" id="mobile-menu">
  <div class="flex flex-col h-full relative p-8">
    
    <!-- Header (inside drawer) -->
    <div class="flex justify-end items-center mb-12">
      <button
        type="button"
        id="mobile-menu-close"
        class="text-slate-500 hover:text-brand-accent p-2 focus:outline-none"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Navigation Links -->
    <nav class="flex flex-col space-y-2">
      {links.map((link, i) => (
        <div class="flex flex-col">
          <div class="flex items-center justify-between py-4 border-b border-slate-50 group">
            <a
              href={link.href}
              class={`text-lg font-medium transition-all duration-300 flex-grow ${
                isActive(link.href)
                  ? 'text-brand-accent'
                  : 'text-brand-blue hover:text-brand-accent'
              }`}
            >
              {link.name}
            </a>
            {link.name === 'Services' && (
              <button 
                class="p-2 text-brand-blue hover:text-brand-accent focus:outline-none transition-transform" 
                id="mobile-services-toggle"
                aria-label="Toggle Services Submenu"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            )}
            {link.name !== 'Services' && (
              <svg class={`w-4 h-4 transform transition-transform group-hover:translate-x-1 ${isActive(link.href) ? 'opacity-100' : 'opacity-30'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            )}
          </div>
          
          {link.name === 'Services' && (
            <div id="mobile-services-menu" class="hidden flex flex-col pl-6 bg-slate-50/50 rounded-lg mt-2 mb-4">
              {SITE_DATA.services.map(service => (
                <a 
                  href={`/services#${service.slug}`}
                  class="py-3 text-sm text-slate-600 hover:text-brand-accent transition-colors border-b border-slate-100 last:border-0"
                >
                  {service.category}
                </a>
              ))}
              <a href="/services" class="py-3 text-sm font-bold text-brand-accent uppercase tracking-wider">
                Explore All Services
              </a>
            </div>
          )}
        </div>
      ))}
    </nav>
    
    <div class="mt-auto pt-10">
      <a 
        href="/contact" 
        class="block w-full text-center bg-brand-blue text-white px-8 py-4 rounded-sm font-bold text-sm tracking-widest uppercase shadow-lg hover:bg-brand-blue-dark transition-all duration-300"
      >
        Contact Us
      </a>
      
      <div class="mt-10 text-center">
         <p class="text-[10px] tracking-[0.2em] text-slate-400 uppercase font-medium">{SITE_DATA.firm.tagline}</p>
         <p class="text-slate-400 text-[10px] mt-2 font-medium tracking-tight">&copy; {new Date().getFullYear()} JDM & Associates</p>
      </div>
    </div>
  </div>
</div>

<script>
  // Add scoll effect to navbar
  const navbar = document.getElementById('navbar');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      navbar?.classList.add('shadow-md');
      navbar?.classList.replace('bg-white/70', 'bg-white/90');
    } else {
      navbar?.classList.remove('shadow-md');
      navbar?.classList.replace('bg-white/90', 'bg-white/70');
    }
  });

  // Mobile menu toggle
  const mobileBtn = document.getElementById('mobile-menu-button');
  const mobileClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileOverlay = document.getElementById('mobile-menu-overlay');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const navbarBg = document.getElementById('navbar');

  const toggleMenu = (open) => {
    const isCurrentlyClosed = mobileMenu?.classList.contains('translate-x-full');
    const shouldOpen = typeof open === 'boolean' ? open : isCurrentlyClosed;

    if (shouldOpen) {
      mobileMenu?.classList.remove('translate-x-full');
      mobileMenu?.classList.add('translate-x-0');
      mobileOverlay?.classList.remove('pointer-events-none', 'opacity-0');
      mobileOverlay?.classList.add('opacity-100');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      navbarBg?.classList.replace('bg-white/70', 'bg-white');
      document.body.style.overflow = 'hidden'; // prevent scrolling
    } else {
      mobileMenu?.classList.add('translate-x-full');
      mobileMenu?.classList.remove('translate-x-0');
      mobileOverlay?.classList.add('pointer-events-none', 'opacity-0');
      mobileOverlay?.classList.remove('opacity-100');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      if(window.scrollY < 10) navbarBg?.classList.replace('bg-white', 'bg-white/70');
      document.body.style.overflow = '';
    }
  };

  mobileBtn?.addEventListener('click', () => toggleMenu());
  mobileClose?.addEventListener('click', () => toggleMenu(false));
  mobileOverlay?.addEventListener('click', () => toggleMenu(false));
  
  // Mobile Services Toggle
  const servicesToggle = document.getElementById('mobile-services-toggle');
  const servicesMenu = document.getElementById('mobile-services-menu');
  
  servicesToggle?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    const isHidden = servicesMenu?.classList.contains('hidden');
    if (isHidden) {
      servicesMenu?.classList.remove('hidden');
      servicesToggle.style.transform = 'rotate(180deg)';
    } else {
      servicesMenu?.classList.add('hidden');
      servicesToggle.style.transform = 'rotate(0deg)';
    }
  });

  // Close menu when clicking a link
  const mobileLinks = mobileMenu?.querySelectorAll('a');
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => toggleMenu(false));
  });
</script>
