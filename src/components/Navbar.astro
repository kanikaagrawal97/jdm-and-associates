---
import Logo from './Logo.astro';
import { SITE_DATA } from '../constants/siteData';

const pathname = Astro.url.pathname;
const isActive = (href) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};

const links = SITE_DATA.navLinks;
---

<header class="fixed top-0 w-full z-50 transition-all duration-300 glass" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="group">
          <Logo 
            variant="dark" 
            className="transform transition-transform duration-300 group-hover:scale-[1.02]"
          />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8 items-center">
        {links.map(link => (
          <a
            href={link.href}
            class={`font-medium text-sm transition-colors ${
              isActive(link.href) 
                ? 'text-brand-accent border-b-2 border-brand-accent font-bold' 
                : 'text-slate-700 hover:text-brand-accent'
            }`}
          >
            {link.name}
          </a>
        ))}
        <a 
          href="/contact" 
          class="bg-brand-blue text-white hover:bg-slate-800 px-5 py-2.5 rounded-sm transition-all duration-300 text-sm font-semibold shadow-md hover:shadow-lg transform hover:-translate-y-0.5"
        >
          Contact Us
        </a>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button
          type="button"
          id="mobile-menu-button"
          class="text-slate-700 hover:text-brand-accent focus:outline-none focus:ring-2 focus:ring-brand-accent p-2"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Icon: Menu -->
          <svg class="h-6 w-6 block" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Icon: Close -->
          <svg class="h-6 w-6 hidden" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>

</header>

<!-- Mobile Menu Overflow Background -->
<div class="md:hidden fixed inset-0 z-40 bg-slate-900/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300" id="mobile-menu-overlay"></div>

<!-- Mobile Menu Drawer -->
<div class="md:hidden fixed top-0 right-0 bottom-0 w-[85%] max-w-sm z-50 bg-white shadow-2xl transform transition-transform duration-500 translate-x-full overflow-y-auto" id="mobile-menu">
  <div class="flex flex-col h-full relative p-8">
    
    <!-- Header (inside drawer) -->
    <div class="flex justify-end items-center mb-12">
      <button
        type="button"
        id="mobile-menu-close"
        class="text-slate-500 hover:text-brand-accent p-2 focus:outline-none"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Navigation Links -->
    <nav class="flex flex-col space-y-2">
      {links.map((link, i) => (
        <a
          href={link.href}
          class={`flex items-center justify-between py-4 border-b border-slate-50 text-lg font-medium transition-all duration-300 group ${
            isActive(link.href)
              ? 'text-brand-accent'
              : 'text-slate-700 hover:text-brand-accent'
          }`}
        >
          <span>{link.name}</span>
          <svg class={`w-4 h-4 transform transition-transform group-hover:translate-x-1 ${isActive(link.href) ? 'opacity-100' : 'opacity-30'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ))}
    </nav>
    
    <div class="mt-auto pt-10">
      <a 
        href="/contact" 
        class="block w-full text-center bg-brand-blue text-white px-8 py-4 rounded-sm font-bold text-sm tracking-widest uppercase shadow-lg hover:bg-slate-800 transition-all duration-300"
      >
        Contact Us
      </a>
      
      <div class="mt-10 text-center">
         <p class="text-[10px] tracking-[0.2em] text-slate-400 uppercase font-medium">{SITE_DATA.firm.tagline}</p>
         <div class="flex justify-center space-x-4 mt-6">
            <!-- Social media placeholders or similar could go here -->
         </div>
         <p class="text-slate-400 text-[10px] mt-2 font-medium tracking-tight">&copy; {new Date().getFullYear()} JDM & Associates</p>
      </div>
    </div>
  </div>
</div>

<script>
  // Add scoll effect to navbar
  const navbar = document.getElementById('navbar');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      navbar?.classList.add('shadow-md');
      navbar?.classList.replace('bg-white/70', 'bg-white/90');
    } else {
      navbar?.classList.remove('shadow-md');
      navbar?.classList.replace('bg-white/90', 'bg-white/70');
    }
  });

  // Mobile menu toggle
  const mobileBtn = document.getElementById('mobile-menu-button');
  const mobileClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileOverlay = document.getElementById('mobile-menu-overlay');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const navbarBg = document.getElementById('navbar');

  const toggleMenu = (open) => {
    const isCurrentlyClosed = mobileMenu?.classList.contains('translate-x-full');
    const shouldOpen = typeof open === 'boolean' ? open : isCurrentlyClosed;

    if (shouldOpen) {
      mobileMenu?.classList.remove('translate-x-full');
      mobileMenu?.classList.add('translate-x-0');
      mobileOverlay?.classList.remove('pointer-events-none', 'opacity-0');
      mobileOverlay?.classList.add('opacity-100');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      navbarBg?.classList.replace('bg-white/70', 'bg-white');
      document.body.style.overflow = 'hidden'; // prevent scrolling
    } else {
      mobileMenu?.classList.add('translate-x-full');
      mobileMenu?.classList.remove('translate-x-0');
      mobileOverlay?.classList.add('pointer-events-none', 'opacity-0');
      mobileOverlay?.classList.remove('opacity-100');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      if(window.scrollY < 10) navbarBg?.classList.replace('bg-white', 'bg-white/70');
      document.body.style.overflow = '';
    }
  };

  mobileBtn?.addEventListener('click', () => toggleMenu());
  mobileClose?.addEventListener('click', () => toggleMenu(false));
  mobileOverlay?.addEventListener('click', () => toggleMenu(false));
  
  // Close menu when clicking a link
  const mobileLinks = mobileMenu?.querySelectorAll('a');
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => toggleMenu(false));
  });
</script>
