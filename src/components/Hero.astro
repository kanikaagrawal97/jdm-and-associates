---
import { SITE_DATA } from '../constants/siteData';

interface Props {
  title?: string;
  subtitle?: string;
  image?: string;
  isMain?: boolean;
  showSocials?: boolean;
}

const { 
  title = SITE_DATA.firm.name, 
  subtitle = SITE_DATA.firm.description,
  image = SITE_DATA.images.heroMain,
  isMain = true,
  showSocials = false
} = Astro.props;
---

<section class={`relative w-full ${isMain ? 'min-h-[70vh]' : 'min-h-[40vh]'} flex items-center justify-center overflow-hidden`}>
  <!-- Background Image & Overlay -->
  <div class="absolute inset-0 z-0 bg-brand-blue">
    <img 
      src={image} 
      alt="Corporate Office Background" 
      fetchpriority="high"
      loading="eager"
      decoding="async"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-brand-blue/80 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-brand-blue via-brand-blue/60 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class={`relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white w-full ${isMain ? 'py-16 lg:py-20' : (showSocials ? 'pt-16 pb-32 lg:pt-20 lg:pb-32' : 'py-12 lg:py-16')}`}>
    {isMain && (
      <span class="inline-block py-1 px-3 rounded-full bg-brand-accent/20 border border-brand-accent/50 text-brand-accent font-medium text-xs mb-6 animate-on-scroll is-visible uppercase tracking-widest">
        {SITE_DATA.firm.tagline}
      </span>
    )}
    
    <h1 class={`font-serif font-bold tracking-tight mb-6 animate-on-scroll stagger-1 is-visible ${isMain ? 'text-4xl sm:text-5xl lg:text-6xl' : 'text-3xl sm:text-4xl lg:text-5xl'}`}>
      {title}
    </h1>
    
    <p class={`mx-auto text-slate-200 animate-on-scroll stagger-2 is-visible ${isMain ? 'max-w-2xl text-lg leading-relaxed mb-10' : (showSocials ? 'max-w-xl text-lg mb-8' : 'max-w-xl text-lg mb-0')}`}>
      {subtitle}
    </p>


    {isMain && (
      <div class="flex flex-row flex-wrap justify-center items-center gap-4 sm:gap-6 animate-on-scroll stagger-3 is-visible">
        <a 
          href="/about" 
          class="group relative inline-flex items-center gap-3 px-8 py-3 bg-white/10 hover:bg-white border border-white/20 hover:border-white text-white hover:text-brand-blue font-bold rounded-full transition-all duration-500 hover:-translate-y-1 whitespace-nowrap backdrop-blur-sm"
        >
          <span>View Details</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-accent group-hover:text-white transition-colors duration-300 group-hover:translate-x-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
         <a 
          href="/services" 
         class="group relative inline-flex items-center gap-3 px-8 py-3 bg-white/10 hover:bg-white border border-white/20 hover:border-white text-white hover:text-brand-blue font-bold rounded-full transition-all duration-500 hover:-translate-y-1 whitespace-nowrap backdrop-blur-sm"
        >
          <span>Our Services</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-accent transition-colors duration-300 group-hover:scale-110"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path></svg>
        </a>
        <a 
          href="/contact" 
          class="group relative inline-flex items-center gap-3 px-8 py-3 bg-white/10 hover:bg-white border border-white/20 hover:border-white text-white hover:text-brand-blue font-bold rounded-full transition-all duration-500 hover:-translate-y-1 whitespace-nowrap backdrop-blur-sm"
        >
          <span>Contact Us</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-accent transition-colors duration-300 group-hover:scale-110"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        </a>
      </div>
    )}
  </div>
</section>
