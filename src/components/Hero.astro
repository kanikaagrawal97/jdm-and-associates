---
import { SITE_DATA } from '../constants/siteData';

interface Props {
  title?: string;
  subtitle?: string;
  image?: string;
  isMain?: boolean;
  showSocials?: boolean;
}

const { 
  title = SITE_DATA.firm.name, 
  subtitle = SITE_DATA.firm.description,
  image = SITE_DATA.images.heroMain,
  isMain = true,
  showSocials = false
} = Astro.props;
---

<section class={`relative w-full ${isMain ? 'min-h-[70vh]' : 'min-h-[40vh]'} flex items-center justify-center overflow-hidden`}>
  <!-- Background Image & Overlay -->
  <div class="absolute inset-0 z-0 bg-brand-blue">
    <img 
      src={image} 
      alt="Corporate Office Background" 
      fetchpriority="high"
      loading="eager"
      decoding="async"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-brand-blue/80 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-brand-blue via-brand-blue/60 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class={`relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white w-full ${isMain ? 'py-16 lg:py-20' : (showSocials ? 'pt-16 pb-32 lg:pt-20 lg:pb-32' : 'py-12 lg:py-16')}`}>
    {isMain && (
      <span class="inline-block py-1 px-3 rounded-full bg-brand-accent/20 border border-brand-accent/50 text-brand-accent font-medium text-xs mb-6 animate-on-scroll is-visible uppercase tracking-widest">
        {SITE_DATA.firm.tagline}
      </span>
    )}
    
    <h1 class={`font-serif font-bold tracking-tight mb-6 animate-on-scroll stagger-1 is-visible ${isMain ? 'text-4xl sm:text-5xl lg:text-6xl' : 'text-3xl sm:text-4xl lg:text-5xl'}`}>
      {title}
    </h1>
    
    <p class={`mx-auto text-slate-200 animate-on-scroll stagger-2 is-visible ${isMain ? 'max-w-2xl text-lg leading-relaxed mb-10' : (showSocials ? 'max-w-xl text-lg mb-8' : 'max-w-xl text-lg mb-0')}`}>
      {subtitle}
    </p>

    {showSocials && (
      <div class="flex justify-center space-x-6 animate-on-scroll stagger-3 is-visible mb-6">
        {SITE_DATA.contact.socials.linkedin && (
          <a href={SITE_DATA.contact.socials.linkedin} target="_blank" rel="noopener noreferrer" class="text-white hover:text-brand-accent transition-colors" aria-label="LinkedIn">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        )}
        {SITE_DATA.contact.socials.instagram && SITE_DATA.contact.socials.instagram !== '#' && (
          <a href={SITE_DATA.contact.socials.instagram} target="_blank" rel="noopener noreferrer" class="text-white hover:text-brand-accent transition-colors" aria-label="Instagram">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        )}
        {SITE_DATA.contact.socials.facebook && SITE_DATA.contact.socials.facebook !== '#' && (
          <a href={SITE_DATA.contact.socials.facebook} target="_blank" rel="noopener noreferrer" class="text-white hover:text-brand-accent transition-colors" aria-label="Facebook">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        )}
      </div>
    )}

    {isMain && (
      <div class="flex flex-col sm:flex-row justify-center items-center space-y-4 sm:space-y-0 sm:space-x-6 animate-on-scroll stagger-3 is-visible">
        <a 
          href="/services" 
          class="px-10 py-3 bg-brand-accent text-white font-bold rounded-sm hover:bg-brand-accent-hover transition-all duration-300 shadow-lg hover:shadow-brand-accent/30 w-full sm:w-auto"
        >
          Our Services
        </a>
        <a 
          href="/contact" 
          class="px-10 py-3 bg-white/10 backdrop-blur-sm border border-white/30 text-white font-bold rounded-sm hover:bg-white/20 transition-all duration-300 w-full sm:w-auto"
        >
          Contact Us
        </a>
      </div>
    )}
  </div>
</section>
