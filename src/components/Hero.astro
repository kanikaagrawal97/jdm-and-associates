---
import { SITE_DATA } from '../constants/siteData';

interface Props {
  title?: string;
  subtitle?: string;
  image?: string;
  isMain?: boolean;
  showSocials?: boolean;
}

const { 
  title = SITE_DATA.firm.name, 
  subtitle = SITE_DATA.firm.description,
  image = SITE_DATA.images.heroMain,
  isMain = true,
  showSocials = false
} = Astro.props;
---

<section class={`relative w-full ${isMain ? 'min-h-[70vh]' : 'min-h-[40vh]'} flex items-center justify-center overflow-hidden`}>
  <!-- Background Image & Overlay -->
  <div class="absolute inset-0 z-0 bg-brand-blue">
    <img 
      src={image} 
      alt="Corporate Office Background" 
      fetchpriority="high"
      loading="eager"
      decoding="async"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-brand-blue/80 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-brand-blue via-brand-blue/60 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class={`relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white w-full ${isMain ? 'py-16 lg:py-20' : (showSocials ? 'pt-16 pb-32 lg:pt-20 lg:pb-32' : 'py-12 lg:py-16')}`}>
    {isMain && (
      <span class="inline-block py-1 px-3 rounded-full bg-brand-accent/20 border border-brand-accent/50 text-brand-accent font-medium text-xs mb-6 animate-on-scroll is-visible uppercase tracking-widest">
        {SITE_DATA.firm.tagline}
      </span>
    )}
    
    <h1 class={`font-serif font-bold tracking-tight mb-6 animate-on-scroll stagger-1 is-visible ${isMain ? 'text-4xl sm:text-5xl lg:text-6xl' : 'text-3xl sm:text-4xl lg:text-5xl'}`}>
      {title}
    </h1>
    
    <p class={`mx-auto text-slate-200 animate-on-scroll stagger-2 is-visible ${isMain ? 'max-w-2xl text-lg leading-relaxed mb-10' : (showSocials ? 'max-w-xl text-lg mb-8' : 'max-w-xl text-lg mb-0')}`}>
      {subtitle}
    </p>


    {isMain && (
      <div class="flex flex-col sm:flex-row justify-center items-center space-y-4 sm:space-y-0 sm:space-x-6 animate-on-scroll stagger-3 is-visible">
        <a 
          href="/services" 
          class="px-10 py-3 bg-brand-accent text-white font-bold rounded-sm hover:bg-brand-accent-hover transition-all duration-300 shadow-lg hover:shadow-brand-accent/30 w-full sm:w-auto"
        >
          Our Services
        </a>
        <a 
          href="/contact" 
          class="px-10 py-3 bg-white/10 backdrop-blur-sm border border-white/30 text-white font-bold rounded-sm hover:bg-white/20 transition-all duration-300 w-full sm:w-auto"
        >
          Contact Us
        </a>
      </div>
    )}
  </div>
</section>
