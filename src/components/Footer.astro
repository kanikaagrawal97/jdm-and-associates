---
import { SITE_DATA } from '../constants/siteData';
import Logo from './Logo.astro';
---

<footer class="relative bg-slate-950 text-slate-300 pt-12 pb-8 overflow-hidden">
  <!-- Subtle Background Decorations -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-accent/5 rounded-full blur-[120px] -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-blue/20 rounded-full blur-[120px] translate-y-1/2 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    
    <!-- Main Footer Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      
      <!-- Brand & About -->
      <div class="flex flex-col space-y-4">
        <Logo variant="light" />
        
        <p class="text-sm text-slate-400 leading-relaxed max-w-sm">
          {SITE_DATA.firm.description.split('. ').slice(0, 2).join('. ')}.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="flex flex-col space-y-4">
        <h4 class="text-white font-bold text-sm flex items-center gap-2">
          <span class="w-6 h-[1.5px] bg-brand-accent"></span>
          Company
        </h4>
        <ul class="space-y-2.5">
          {[
            { name: "Home", href: "/" },
            { name: "About Us", href: "/about" },
            { name: "Services", href: "/services" },
            { name: "Our Clients", href: "/client-info" },
            { name: "Contact Us", href: "/contact" },
          ].map(link => (
            <li>
              <a href={link.href} class="group flex items-center space-x-2 text-slate-400 hover:text-white transition-all duration-200 text-sm">
                <span class="w-1 h-1 rounded-full bg-brand-accent/40 scale-0 group-hover:scale-100 transition-transform duration-200"></span>
                <span>{link.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="flex flex-col space-y-4 text-sm">
        <h4 class="text-white font-bold text-sm flex items-center gap-2">
          <span class="w-6 h-[1.5px] bg-brand-accent"></span>
          Reach Us
        </h4>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded bg-brand-accent/10 border border-brand-accent/20 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div class="flex flex-col gap-1">
              {SITE_DATA.contact.emails.map((email) => (
                <a href={`mailto:${email}`} class="text-slate-300 hover:text-brand-accent transition-colors duration-200 block truncate max-w-[180px]">{email}</a>
              ))}
            </div>
          </div>
          
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded bg-brand-accent/10 border border-brand-accent/20 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <div class="flex flex-col gap-1">
              {SITE_DATA.contact.phones.map(phone => (
                <a href={`tel:${phone.replace(/\\s/g, '')}`} class="text-slate-300 hover:text-brand-accent transition-colors duration-200 block whitespace-nowrap">
                  {phone}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Locations -->
      <div class="flex flex-col space-y-4">
        <h4 class="text-white font-bold text-sm flex items-center gap-2">
          <span class="w-6 h-[1.5px] bg-brand-accent"></span>
          Our Offices
        </h4>
        <div class="space-y-4 max-h-[250px] overflow-y-auto pr-2 custom-scrollbar">
          {SITE_DATA.contact.offices.map(office => (
            <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(office.address)}`} target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 group">
              <div class="w-8 h-8 rounded bg-white/5 border border-white/10 flex items-center justify-center shrink-0 group-hover:border-brand-accent/30 transition-colors">
                <svg class="w-4 h-4 text-slate-500 group-hover:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <div class="min-w-0">
                <p class="text-white font-semibold text-[13px] mb-0.5 leading-tight group-hover:text-brand-accent transition-colors">{office.city}</p>
                <p class="text-slate-500 text-[11px] leading-relaxed line-clamp-2 group-hover:text-slate-400 transition-colors">{office.address}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Footer Bottom -->
    <div class="pt-6 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex flex-col md:flex-row items-center gap-4 md:gap-6 text-[11px] text-slate-500 font-medium">
        <p>© {new Date().getFullYear()} {SITE_DATA.firm.name}.</p>
        <div class="flex items-center gap-4">
          <a href="/privacy" class="hover:text-white transition-colors duration-200">Privacy Policy</a>
          <a href="/terms" class="hover:text-white transition-colors duration-200">Terms of Service</a>
        </div>
      </div>
      
      <div class="flex items-center gap-2.5">
        <p class="text-[9px] text-slate-600 uppercase tracking-widest font-bold">Accredited by</p>
        <div class="px-2 py-1 rounded bg-white/5 border border-white/5 text-[9px] text-brand-accent font-black tracking-widest uppercase">
          ICSI
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 3px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.02);
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(217, 119, 6, 0.2);
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(217, 119, 6, 0.4);
  }
</style>
