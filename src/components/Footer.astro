---
import { SITE_DATA } from '../constants/siteData';
import Logo from './Logo.astro';
---

<footer class="relative text-slate-200 pt-12 pb-8 overflow-hidden" style="background: linear-gradient(180deg, #1B5091 0%, #133B6B 40%, #0E2B4D 100%);">
  <!-- Gold accent strip at top -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-brand-accent to-transparent"></div>
  
  <!-- Subtle Background Decorations -->
  <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-brand-accent/8 rounded-full blur-[150px] -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-[600px] h-[600px] bg-[#0a2040]/40 rounded-full blur-[150px] translate-y-1/3 pointer-events-none"></div>
  
  <!-- Subtle texture -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 20px 20px;"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    
    <!-- Main Footer Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10 md:gap-12 lg:gap-8 mb-10 md:mb-16">
      
      <!-- Column 1: Brand & Reach Us -->
      <div class="lg:col-span-3 flex flex-col space-y-10">
        <div class="space-y-6">
          <div class="flex items-center gap-4 sm:gap-6">
            <div class="bg-white rounded-lg p-1.5 shadow-xl glass border-white/20">
              <img 
                src="/images/cs_logo.png" 
                alt="Company Secretary Logo" 
                class="h-10 w-auto"
              />
            </div>
            <div class="h-10 w-px bg-white/10 hidden sm:block"></div>
            <Logo variant="light" />
          </div>
          <div class="space-y-1.5 border-l-2 border-brand-accent/30 pl-4 py-1">
            <p class="text-[10px] text-white/40 font-bold uppercase tracking-widest leading-none">
              {SITE_DATA.firm.tagline}
            </p>
            <p class="text-[15px] text-slate-300 font-serif italic tracking-wide">
              "{SITE_DATA.firm.motto}"
            </p>
          </div>
        </div>

        <div class="space-y-4">
          <h4 class="text-white font-bold text-[10px] uppercase tracking-[0.2em] flex items-center gap-2">
            <span class="w-4 h-[2px] bg-brand-accent"></span>
            Reach Us
          </h4>
          <div class="space-y-3">
            {SITE_DATA.contact.emails.map((item) => (
            <a href={`mailto:${item.email}`} class="group flex items-center gap-2.5 text-slate-300 hover:text-brand-accent transition-all duration-300">
              <div class="w-7 h-7 rounded bg-white/10 flex items-center justify-center shrink-0 group-hover:bg-brand-accent/20 transition-colors">
                <svg class="w-3.5 h-3.5 text-white/60 group-hover:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <!-- email_off --><span class="text-[13px] font-medium tracking-wide truncate">{item.email}</span><!-- /email_off -->
            </a>
          ))}
          
          {SITE_DATA.contact.phones.map(item => (
            <a href={`tel:${item.number.replace(/\s+/g, '')}`} class="group flex items-center gap-2.5 text-slate-300 hover:text-brand-accent transition-all duration-300">
              <div class="w-7 h-7 rounded bg-white/10 flex items-center justify-center shrink-0 group-hover:bg-brand-accent/20 transition-colors">
                <svg class="w-3.5 h-3.5 text-white/60 group-hover:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <span class="text-[13px] font-medium tracking-wide whitespace-nowrap">{item.number}</span>
            </a>
          ))}</div>
        </div>
      </div>

      <!-- Columns 2-4: Offices -->
      {SITE_DATA.contact.offices.map((office, idx) => (
        <div class="lg:col-span-3 flex flex-col space-y-4">
          <h4 class="text-white font-bold text-[10px] uppercase tracking-[0.2em] flex items-center gap-2">
            <span class="w-4 h-[2px] bg-brand-accent"></span>
            {idx === 0 ? 'Head Office' : 'Branch Office'}
          </h4>
          
          <div class="group space-y-3 pl-6 border-l border-white/10 hover:border-brand-accent/40 transition-colors">
            <h5 class="text-white font-bold text-[13px] tracking-wide group-hover:text-brand-accent transition-colors duration-300">
              {office.branch}
            </h5>
            
            <p class="text-slate-300/70 text-[12px] leading-relaxed group-hover:text-slate-300 transition-colors min-h-[66px]">
              {office.address}
            </p>
            
            {(office.email || office.phone || office.contactPerson) && (
              <div class="flex flex-col gap-3.5 pt-4 border-t border-white/10">
                {office.contactPerson && (
                  <div class="flex flex-col gap-0.5">
                    <p class="text-[13px] text-white font-bold tracking-wide">{office.contactPerson}</p>
                  </div>
                )}
                <div class="flex flex-col gap-2.5">
                  {office.email && (
                    <a href={`mailto:${office.email}`} class="text-slate-300 hover:text-brand-accent transition-all duration-300 flex items-center gap-2.5 group/link">
                      <div class="w-7 h-7 rounded bg-white/10 flex items-center justify-center shrink-0 group-hover/link:bg-brand-accent/20 transition-colors">
                        <svg class="w-3.5 h-3.5 text-white/60 group-hover/link:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                      </div>
                      <!-- email_off --><span class="text-[13px] font-medium truncate">{office.email}</span><!-- /email_off -->
                    </a>
                  )}
                  {office.phone && (
                    <a href={`tel:${office.phone.replace(/\s/g, '')}`} class="text-slate-300 hover:text-brand-accent transition-all duration-300 flex items-center gap-2.5 group/link">
                      <div class="w-7 h-7 rounded bg-white/10 flex items-center justify-center shrink-0 group-hover/link:bg-brand-accent/20 transition-colors">
                        <svg class="w-3.5 h-3.5 text-white/60 group-hover/link:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                      </div>
                      <span class="text-[13px] font-medium whitespace-nowrap">{office.phone}</span>
                    </a>
                  )}
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
    
    <!-- Footer Bottom -->
    <div class="pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex flex-col md:flex-row items-center gap-4 md:gap-6 text-[11px] text-slate-400 font-medium">
        <p>© {new Date().getFullYear()} {SITE_DATA.firm.name}.</p>
        <div class="flex items-center gap-4">
          <a href="/privacy" class="hover:text-white transition-colors duration-200">Privacy Policy</a>
          <a href="/terms" class="hover:text-white transition-colors duration-200">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</footer>
