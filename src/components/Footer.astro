---
import { SITE_DATA } from '../constants/siteData';
import Logo from './Logo.astro';
---

<footer class="relative bg-slate-950 text-slate-300 pt-12 pb-8 overflow-hidden">
  <!-- Subtle Background Decorations -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-accent/5 rounded-full blur-[120px] -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-blue/20 rounded-full blur-[120px] translate-y-1/2 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    
    <!-- Horizontal Footer Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-16">
      
      <!-- Column 1: Brand & Reach Us (Takes 3/12 space) -->
      <div class="lg:col-span-3 flex flex-col space-y-10">
        <div class="space-y-5">
          <Logo variant="light" />
          <div class="space-y-1.5 border-l-2 border-brand-accent/20 pl-4 py-1">
            <p class="text-[10px] text-white/50 font-bold uppercase tracking-widest leading-none">
              {SITE_DATA.firm.tagline}
            </p>
            <p class="text-[15px] text-slate-300 font-serif italic tracking-wide">
              “{SITE_DATA.firm.motto}”
            </p>
          </div>
        </div>

        <div class="space-y-4">
          <h4 class="text-white font-bold text-[10px] uppercase tracking-[0.2em] flex items-center gap-2">
            <span class="w-4 h-[1px] bg-brand-accent/30"></span>
            Reach Us
          </h4>
          <div class="space-y-3">
            {SITE_DATA.contact.emails.map((item) => (
            <a href={`mailto:${item.email}`} class="group flex items-center gap-2.5 text-slate-400 hover:text-brand-accent transition-all duration-300">
              <div class="w-7 h-7 rounded bg-white/5 flex items-center justify-center shrink-0 group-hover:bg-brand-accent/10 transition-colors">
                <svg class="w-3.5 h-3.5 text-slate-500 group-hover:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <span class="text-[12px] font-medium tracking-wide truncate">{item.email}</span>
            </a>
          ))}
          
          {SITE_DATA.contact.phones.map(item => (
            <a href={`tel:${item.number.replace(/\s/g, '')}`} class="group flex items-center gap-2.5 text-slate-400 hover:text-brand-accent transition-all duration-300">
              <div class="w-7 h-7 rounded bg-white/5 flex items-center justify-center shrink-0 group-hover:bg-brand-accent/10 transition-colors">
                <svg class="w-3.5 h-3.5 text-slate-500 group-hover:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <span class="text-[12px] font-medium tracking-wide whitespace-nowrap">{item.number}</span>
            </a>
          ))}</div>
        </div>
      </div>

      <!-- Columns 2-4: Individual Offices (Each takes 3/12 space) -->
      {SITE_DATA.contact.offices.map((office, idx) => (
        <div class="lg:col-span-3 flex flex-col space-y-4">
          <h4 class="text-white font-bold text-[10px] uppercase tracking-[0.2em] flex items-center gap-2">
            <span class="w-4 h-[1px] bg-brand-accent/30"></span>
            {idx === 0 ? 'Head Office' : 'Branch Office'}
          </h4>
          
          <div class="group space-y-3 pl-6 border-l border-white/5 hover:border-brand-accent/30 transition-colors">
            <h5 class="text-white font-bold text-[13px] tracking-wide group-hover:text-brand-accent transition-colors duration-300">
              {office.city}
            </h5>
            
            <p class="text-slate-500 text-[11px] leading-relaxed group-hover:text-slate-400 transition-colors min-h-[66px]">
              {office.address}
            </p>
            
            {(office.email || office.phone || office.contactPerson) && (
              <div class="flex flex-col gap-3.5 pt-4 border-t border-white/5">
                {office.contactPerson && (
                  <div class="flex flex-col gap-0.5">
                    <p class="text-[13px] text-white font-bold tracking-wide">{office.contactPerson}</p>
                  </div>
                )}
                <div class="flex flex-col gap-2.5">
                  {office.email && (
                    <a href={`mailto:${office.email}`} class="text-slate-400 hover:text-brand-accent transition-all duration-300 flex items-center gap-2.5 group/link">
                      <div class="w-7 h-7 rounded bg-white/5 flex items-center justify-center shrink-0 group-hover/link:bg-brand-accent/10 transition-colors">
                        <svg class="w-3.5 h-3.5 text-slate-500 group-hover/link:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                      </div>
                      <span class="text-[12px] font-medium truncate">{office.email}</span>
                    </a>
                  )}
                  {office.phone && (
                    <a href={`tel:${office.phone.replace(/\s/g, '')}`} class="text-slate-400 hover:text-brand-accent transition-all duration-300 flex items-center gap-2.5 group/link">
                      <div class="w-7 h-7 rounded bg-white/5 flex items-center justify-center shrink-0 group-hover/link:bg-brand-accent/10 transition-colors">
                        <svg class="w-3.5 h-3.5 text-slate-500 group-hover/link:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                      </div>
                      <span class="text-[12px] font-medium whitespace-nowrap">{office.phone}</span>
                    </a>
                  )}
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
    
    <!-- Footer Bottom -->
    <div class="pt-6 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex flex-col md:flex-row items-center gap-4 md:gap-6 text-[11px] text-slate-500 font-medium">
        <p>© {new Date().getFullYear()} {SITE_DATA.firm.name}.</p>
        <div class="flex items-center gap-4">
          <a href="/privacy" class="hover:text-white transition-colors duration-200">Privacy Policy</a>
          <a href="/terms" class="hover:text-white transition-colors duration-200">Terms of Service</a>
        </div>
      </div>
      
      <div class="flex items-center gap-2.5">
        <p class="text-[9px] text-slate-600 uppercase tracking-widest font-bold">Accredited by</p>
        <div class="px-2 py-1 rounded bg-white/5 border border-white/5 text-[9px] text-brand-accent font-black tracking-widest uppercase">
          ICSI
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Simplified style - custom scrollbar no longer needed */
</style>
