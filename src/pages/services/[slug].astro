---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { SITE_DATA } from '../../constants/siteData';

export async function getStaticPaths() {
  return SITE_DATA.services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
console.log("Service Short Summary:", service.shortSummary);
// Trigger refresh 1

// Specific Architecture Icons
const getIconPath = (cat: string) => {
  const lowerCat = cat.toLowerCase();
  if (lowerCat.includes('startup')) return "M13 10V3L4 14h7v7l9-11h-7z";
  if (lowerCat.includes('compliance')) return "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z";
  if (lowerCat.includes('audit')) return "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01";
  if (lowerCat.includes('fema')) return "M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9";
  if (lowerCat.includes('xbrl')) return "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4";
  if (lowerCat.includes('restructuring')) return "M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3";
  if (lowerCat.includes('bank')) return "M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z";
  if (lowerCat.includes('sebi')) return "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6";
  return "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4";
};
---

<BaseLayout 
  title={service.category}
  description={`${service.shortSummary} JDM and Associates LLP provides expert ${service.category} services across Surat, Mumbai, and Chennai.`}
  image={service.image}
  type="article"
>
  
  <header class="relative pt-12 md:pt-20 pb-10 md:pb-16 bg-brand-light overflow-hidden">
     <!-- Fine Background Fine Line -->
     <div class="absolute inset-0 pointer-events-none opacity-5">
        <div class="absolute top-[10%] left-0 w-full h-px bg-slate-900"></div>
        <div class="absolute top-[90%] left-0 w-full h-px bg-slate-900"></div>
     </div>

     <div class="max-w-7xl mx-auto px-4 relative z-10 flex flex-col md:flex-row items-end justify-between gap-12">
        <div class="max-w-3xl animate-on-scroll">
           <div class="h-1.5 w-12 bg-brand-accent mb-8"></div>
           <h1 class="font-serif text-3xl sm:text-5xl lg:text-6xl font-bold text-brand-blue leading-[1.05] tracking-tighter uppercase mb-6 md:mb-8">
             {service.category}
           </h1>
           <p class="text-slate-500 text-lg sm:text-xl font-medium leading-relaxed italic border-l-4 border-slate-100 pl-6">
             {service.shortSummary}
           </p>
        </div>
        <div class="hidden lg:block pb-5 animate-on-scroll stagger-1">
           <div class="w-16 h-16 rounded-full border-2 border-slate-100 flex items-center justify-center animate-bounce">
              <svg class="w-6 h-6 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
           </div>
        </div>
     </div>
  </header>

  <section class="py-12 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <!-- Imagery (Persistent Architectural Cut) -->
        <div class="lg:col-span-5 relative animate-on-scroll slide-in-left">
           <!-- Dot Matrix Behind -->
           <div class="absolute -top-6 -left-6 md:-top-10 md:-left-10 w-24 h-24 md:w-40 md:h-40 opacity-[0.05] z-0" style="background-image: radial-gradient(#1B5091 2px, transparent 2px); background-size: 15px 15px;"></div>
           
           <!-- Portal Frame -->
           <div class="absolute -inset-2 md:-inset-4 border border-slate-100 rounded-[2rem] md:rounded-[8rem] rounded-tr-none md:rounded-tr-none rounded-bl-none md:rounded-bl-none z-0"></div>

           <div class="relative z-10 aspect-[4/5] rounded-[2rem] md:rounded-[8rem] rounded-tr-none md:rounded-tr-none rounded-bl-none md:rounded-bl-none overflow-hidden border-4 border-white shadow-2xl bg-slate-50">
              <img 
                src={service.image} 
                alt={service.category} 
                fetchpriority="high" 
                loading="eager" 
                decoding="async" 
                class="w-full h-full object-cover grayscale-[0.15] md:grayscale-[0.3] hover:grayscale-0 transition-all duration-[3s] parallax-image" 
              />
           </div>
        </div>

        <!-- Detailed Mandates -->
        <div class="lg:col-span-7 space-y-12 animate-on-scroll slide-in-right stagger-2">
           <div>
              <h2 class="font-serif text-2xl font-bold text-brand-blue mb-8 tracking-tight uppercase underline decoration-brand-accent/30 decoration-4 underline-offset-8">Practice Scope</h2>
              
              <div class="space-y-2">
                {service.items.map((item) => (
                  <div class="group/li border-b border-slate-50 py-3 hover:border-brand-accent/20 transition-all duration-300">
                    {typeof item === 'string' ? (
                      <div class="flex items-start gap-4">
                        <div class="mt-1.5 shrink-0 text-brand-accent">
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                          </svg>
                        </div>
                        <p class="text-[15px] md:text-base font-medium text-slate-700 leading-relaxed group-hover/li:text-brand-blue transition-colors duration-300">
                          {item}
                        </p>
                      </div>
                    ) : (
                      <div class="space-y-4">
                        <div class="flex items-start gap-4">
                          <div class="mt-1.5 shrink-0 text-brand-accent">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                            </svg>
                          </div>
                          <h3 class="text-[15px] md:text-base font-bold text-brand-blue leading-relaxed">
                            {item.title}
                          </h3>
                        </div>
                        
                        <div class="ml-10 space-y-3 pt-1 border-l-2 border-slate-100 pl-6">
                          {item.points && item.points.map((point) => (
                            <div class="flex items-start gap-3 group/point">
                              <div class="mt-2.5 shrink-0 w-1.5 h-1.5 rounded-full bg-slate-300 group-hover/point:bg-brand-accent transition-colors"></div>
                              <span class="text-[14px] md:text-[15px] text-slate-600 leading-relaxed">
                                {point}
                              </span>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                ))}
              </div>
           </div>

           <div class="flex flex-col sm:flex-row items-center gap-6 md:gap-8 pt-8 border-t border-slate-50">
              <a href="/contact" class="w-full sm:w-auto group/cta inline-flex items-center justify-center bg-brand-blue text-white px-10 md:px-12 py-4 md:py-5 rounded-full hover:bg-brand-accent transition-all duration-500 shadow-xl">
                 <span class="font-black tracking-[0.4em] text-[10px] uppercase text-white">Consult Partner</span>
                 <svg class="w-6 h-6 ml-4 transform group-hover/cta:translate-x-3 transition-transform text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
              </a>
              <a href="/services" onclick="if (document.referrer.includes(window.location.host)) { event.preventDefault(); window.history.back(); }" class="font-black tracking-[0.3em] text-[10px] text-slate-400 uppercase hover:text-brand-blue transition-colors border-b border-transparent hover:border-brand-blue pb-1">Back to Practice Areas</a>
           </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>
