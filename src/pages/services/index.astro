---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { SITE_DATA } from '../../constants/siteData';

const categories = SITE_DATA.services;
---

<BaseLayout title="Practice Areas | JDM & Associates" description="Expert corporate advisory and global compliance mandates.">
  
  <Hero 
    title="Services We Provide" 
    subtitle="Comprehensive corporate advisory, governance, and compliance solutions tailored for your business needs." 
    image="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1280&q=60"
    isMain={false}
  />

  <!-- Sticky Service Navigation -->
  <div class="sticky top-20 z-40 bg-white shadow-sm border-b border-slate-100" id="service-nav">
    <div class="max-w-7xl mx-auto h-16 flex items-center px-4">
      
      <!-- Left Arrow -->
      <button 
        id="scroll-left" 
        class="flex-shrink-0 w-12 h-12 flex items-center justify-center text-brand-blue hover:text-brand-accent transition-all duration-300 opacity-0 pointer-events-none"
        aria-label="Scroll Left"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <!-- Scrollable Container -->
      <div 
        class="flex-1 flex items-center overflow-x-auto no-scrollbar gap-8 sm:gap-12 justify-start snap-x snap-mandatory" 
        id="nav-scroll-container"
      >
        {categories.map((service) => (
          <a 
            href={`#${service.slug}`}
            class="whitespace-nowrap text-[10px] sm:text-[11px] font-black uppercase tracking-[0.25em] text-slate-400 hover:text-brand-accent transition-colors duration-300 flex items-center gap-2 group/nav relative py-2 snap-center [scroll-snap-stop:always] shrink-0"
            data-service-nav={service.slug}
          >
            <span class="w-1.5 h-1.5 rounded-full bg-slate-200 group-hover/nav:bg-brand-accent transition-colors"></span>
            {service.category}
            <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-brand-accent transition-all duration-300 group-[.active]:w-full"></div>
          </a>
        ))}
      </div>

      <!-- Right Arrow -->
      <button 
        id="scroll-right" 
        class="flex-shrink-0 w-12 h-12 flex items-center justify-center text-brand-blue hover:text-brand-accent transition-all duration-300 opacity-0 pointer-events-none"
        aria-label="Scroll Right"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
        </svg>
      </button>

    </div>
  </div>

  <!-- The Architectural Cut Services -->
  <section class="py-16 md:py-24 bg-[#FCFCFD] relative overflow-hidden transition-colors duration-700" id="services-grid">
    <!-- Sophisticated Fine Lines -->
    <div class="absolute inset-0 pointer-events-none opacity-10">
       <div class="absolute top-0 left-[20%] h-full w-px bg-slate-400"></div>
       <div class="absolute top-0 left-[80%] h-full w-px bg-slate-400"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <div class="space-y-24 md:space-y-40">
        {categories.map((service, index) => {
          const isEven = index % 2 === 0;
          return (
            <div 
              id={service.slug}
              class={`flex flex-col ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'} items-center gap-16 lg:gap-32 animate-on-scroll ${isEven ? 'slide-in-left' : 'slide-in-right'} group scroll-mt-40`}
            >
              
              <!-- High-Flair Artistic Portal -->
              <div class="w-full lg:w-1/2 relative group/img">
                <!-- Static Outline Frame -->
                <div class="absolute -inset-4 border border-slate-200 rounded-[4rem] lg:rounded-[10rem] rounded-tr-none lg:rounded-tr-none rounded-bl-none lg:rounded-bl-none -z-10 transition-all duration-700 group-hover:border-brand-accent/30 group-hover:scale-105"></div>
                
                <!-- Main Architectural Image -->
                <div class="relative z-10 aspect-[16/11] overflow-hidden rounded-[4rem] lg:rounded-[10rem] rounded-tr-none lg:rounded-tr-none rounded-bl-none lg:rounded-bl-none shadow-2xl border-4 border-white bg-slate-50">
                  <img 
                    src={service.image} 
                    alt={service.category} 
                    class="w-full h-full object-cover rounded-[4rem] lg:rounded-[10rem] rounded-tr-none lg:rounded-tr-none rounded-bl-none lg:rounded-bl-none transition-all duration-1000 grayscale-[0.15] md:grayscale-[0.3] group-hover:grayscale-0 group-hover:scale-110 parallax-image"
                    loading="lazy"
                    decoding="async"
                  />
                  <!-- Glass overlay on hover -->
                  <div class="absolute inset-0 bg-brand-blue/10 opacity-0 group-hover/img:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                </div>
              </div>

              <!-- Content -->
              <div class="w-full lg:w-1/2 space-y-8">
                <div class="space-y-4">
                  <div class="h-1 w-12 bg-brand-accent/20 group-hover:w-24 group-hover:bg-brand-accent transition-all duration-700"></div>
                  <h2 class="font-serif text-3xl lg:text-4xl font-bold text-brand-blue leading-[1.1] tracking-tighter uppercase">
                     {service.category}
                  </h2>
                </div>

                <p class="text-slate-600 text-lg leading-relaxed font-medium border-l-4 border-brand-accent/10 pl-10 max-w-xl italic">
                  {service.shortSummary}
                </p>

                <div class="grid grid-cols-1 gap-4 pt-4">
                   {service.items.slice(0, 4).map(item => (
                     <div class="flex items-start gap-4 group/li">
                        <div class="mt-2 shrink-0 w-2.5 h-2.5 rounded-full bg-slate-200 group-hover/li:bg-brand-accent group-hover/li:scale-125 transition-all duration-300"></div>
                        <span class="text-sm md:text-base font-semibold text-slate-700 leading-relaxed group-hover/li:text-brand-blue transition-colors duration-300">
                          {typeof item === 'string' ? item : item.title}
                        </span>
                     </div>
                   ))}
                </div>

                <div class="pt-6">
                  <a 
                    href={`/services/${service.slug}`} 
                    class="group/cta inline-flex items-center gap-10 bg-brand-blue text-white px-8 md:px-10 py-4 md:py-5 rounded-full hover:bg-brand-accent transition-all duration-500 shadow-xl hover:-translate-y-1"
                  >
                    <span class="font-black tracking-[0.4em] text-[10px] uppercase text-white">View Details</span>
                    <svg class="w-5 h-5 transform group-hover/cta:translate-x-3 transition-transform text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </a>
                </div>
              </div>

            </div>
          )
        })}
      </div>

    </div>
  </section>

  <style>
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .parallax-image {
      will-change: transform;
    }
  </style>

  <script>
    function initServices() {
      const navLinks = document.querySelectorAll('[data-service-nav]');
      const sections = document.querySelectorAll('.animate-on-scroll[id]');
      const navContainer = document.getElementById('nav-scroll-container');
      const scrollLeftBtn = document.getElementById('scroll-left');
      const scrollRightBtn = document.getElementById('scroll-right');
      const servicesSection = document.getElementById('services-grid');

      const handleOverflow = () => {
        if (!navContainer) return;
        const isOverflowing = navContainer.scrollWidth > navContainer.clientWidth;
        if (isOverflowing) {
          navContainer.classList.remove('justify-center');
          navContainer.classList.add('justify-start');
        } else {
          navContainer.classList.add('justify-center');
          navContainer.classList.remove('justify-start');
        }
      };

      const updateArrows = () => {
        if (!navContainer || !scrollLeftBtn || !scrollRightBtn) return;
        const scrollLeft = navContainer.scrollLeft;
        const maxScroll = navContainer.scrollWidth - navContainer.clientWidth;
        
        scrollLeftBtn.classList.toggle('opacity-0', scrollLeft <= 10);
        scrollLeftBtn.classList.toggle('pointer-events-none', scrollLeft <= 10);
        scrollRightBtn.classList.toggle('opacity-0', scrollLeft >= maxScroll - 10);
        scrollRightBtn.classList.toggle('pointer-events-none', scrollLeft >= maxScroll - 10);
      };

      scrollLeftBtn?.addEventListener('click', () => navContainer?.scrollBy({ left: -400, behavior: 'smooth' }));
      scrollRightBtn?.addEventListener('click', () => navContainer?.scrollBy({ left: 400, behavior: 'smooth' }));
      navContainer?.addEventListener('scroll', updateArrows);

      // Intersection Observer for active nav and background change
      const observerOptions = {
        root: null,
        rootMargin: '-45% 0px -45% 0px', // Target the very center of the viewport
        threshold: 0
      };

      const sectionColors = [
        'bg-[#FCFCFD]', // default
        'bg-[#F8FAFC]', 
        'bg-[#F1F5F9]',
        'bg-[#F8FAFC]',
        'bg-[#FCFCFD]'
      ];

      const observer = new IntersectionObserver((entries) => {
        // Filter only intersecting entries and pick the one most likely to be in focus
        const intersecting = entries.filter(e => e.isIntersecting);
        if (intersecting.length === 0) return;
        
        // If multiple are intersecting, pick the one that just entered or is more prominent
        const entry = intersecting[intersecting.length - 1];
        const id = entry.target.getAttribute('id');
        const index = Array.from(sections).indexOf(entry.target);
        
        // Change background color
        if (servicesSection) {
          const colorClass = sectionColors[index % sectionColors.length];
          servicesSection.className = `py-16 md:py-24 relative overflow-hidden transition-colors duration-1000 ${colorClass}`;
        }

        navLinks.forEach(link => {
          const isActive = link.getAttribute('href') === `#${id}`;
          link.classList.toggle('text-brand-accent', isActive);
          link.classList.toggle('active', isActive);
          link.classList.toggle('text-slate-400', !isActive);
          link.querySelector('span')?.classList.toggle('bg-brand-accent', isActive);
          link.querySelector('span')?.classList.toggle('bg-slate-200', !isActive);
          
          if (isActive && navContainer) {
            const linkRect = link.getBoundingClientRect();
            const containerRect = navContainer.getBoundingClientRect();
            const scrollLeftValue = linkRect.left - containerRect.left + navContainer.scrollLeft - (containerRect.width / 2) + (linkRect.width / 2);
            
            const diff = Math.abs(navContainer.scrollLeft - scrollLeftValue);
            if (diff > 2) { // Tighter tolerance
              navContainer.scrollTo({ left: scrollLeftValue, behavior: 'smooth' });
            }
          }
        });
      }, observerOptions);

      sections.forEach(section => observer.observe(section));

      handleOverflow();
      updateArrows();
      window.addEventListener('resize', () => { handleOverflow(); updateArrows(); });
    }

    // Initialize
    initServices();
    document.addEventListener('astro:after-swap', initServices);
  </script>
</BaseLayout>
