---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { SITE_DATA } from '../../constants/siteData';

const categories = SITE_DATA.services;
---

<BaseLayout title="Practice Areas | JDM & Associates" description="Expert corporate advisory and global compliance mandates.">
  
  <Hero 
    title="Services We Provide" 
    subtitle="Comprehensive corporate advisory, governance, and compliance solutions tailored for your business needs." 
    image="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1280&q=60"
    isMain={false}
  />

  <!-- Sticky Service Navigation -->
  <div class="sticky top-20 z-40 bg-white shadow-sm border-b border-slate-100" id="service-nav">
    <div class="max-w-7xl mx-auto h-16 flex items-center px-4">
      
      <!-- Left Arrow -->
      <button 
        id="scroll-left" 
        class="flex-shrink-0 w-12 h-12 flex items-center justify-center text-brand-blue hover:text-brand-accent transition-all duration-300 opacity-0 pointer-events-none"
        aria-label="Scroll Left"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <!-- Scrollable Container -->
      <div 
        class="flex-1 flex items-center overflow-x-auto no-scrollbar scroll-smooth gap-8 sm:gap-12 justify-center" 
        id="nav-scroll-container"
      >
        {categories.map((service) => (
          <a 
            href={`#${service.slug}`}
            class="whitespace-nowrap text-[10px] sm:text-[11px] font-black uppercase tracking-[0.25em] text-slate-400 hover:text-brand-accent transition-colors duration-300 flex items-center gap-2 group/nav relative py-2"
            data-service-nav={service.slug}
          >
            <span class="w-1.5 h-1.5 rounded-full bg-slate-200 group-hover/nav:bg-brand-accent transition-colors"></span>
            {service.category}
            <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-brand-accent transition-all duration-300 group-[.active]:w-full"></div>
          </a>
        ))}
      </div>

      <!-- Right Arrow -->
      <button 
        id="scroll-right" 
        class="flex-shrink-0 w-12 h-12 flex items-center justify-center text-brand-blue hover:text-brand-accent transition-all duration-300 opacity-0 pointer-events-none"
        aria-label="Scroll Right"
      >
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
        </svg>
      </button>

    </div>
  </div>

  <!-- The Architectural Cut Services -->
  <section class="py-24 bg-[#FCFCFD] relative overflow-hidden">
    <!-- Sophisticated Fine Lines -->
    <div class="absolute inset-0 pointer-events-none opacity-10">
       <div class="absolute top-0 left-[20%] h-full w-px bg-slate-300"></div>
       <div class="absolute top-0 left-[80%] h-full w-px bg-slate-300"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <div class="space-y-40">
        {categories.map((service, index) => {
          const isEven = index % 2 === 0;
          return (
            <div 
              id={service.slug}
              class={`flex flex-col ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'} items-center gap-16 lg:gap-32 animate-on-scroll group scroll-mt-40`}
            >
              
              <!-- High-Flair Artistic Portal (Persistent Cut) -->
              <div class="w-full lg:w-1/2 relative">
                <!-- Static Outline Frame (Persistent Cut) -->
                <div class="absolute -inset-4 border border-slate-200 rounded-[4rem] lg:rounded-[10rem] rounded-tr-none lg:rounded-tr-none rounded-bl-none lg:rounded-bl-none -z-10 transition-colors duration-500 group-hover:border-brand-accent/30"></div>
                
                <!-- Dot Matrix (Hidden Behind Image) -->
                <div class={`absolute -top-6 md:-top-10 ${isEven ? '-left-6 md:-left-10' : '-right-6 md:-right-10'} w-20 h-20 md:w-32 md:h-32 opacity-10 pointer-events-none group-hover:opacity-30 transition-opacity z-[-5]`} style="background-image: radial-gradient(#1B5091 2px, transparent 2px); background-size: 10px 10px;"></div>

                <!-- Main Architectural Image (Persistent Cut) -->
                <div class="relative z-10 aspect-[16/11] overflow-hidden rounded-[4rem] lg:rounded-[10rem] rounded-tr-none lg:rounded-tr-none rounded-bl-none lg:rounded-bl-none shadow-2xl border-4 border-white bg-slate-50">
                  <img 
                    src={service.image} 
                    alt={service.category} 
                    class="w-full h-full object-cover rounded-[4rem] lg:rounded-[10rem] rounded-tr-none lg:rounded-tr-none rounded-bl-none lg:rounded-bl-none transition-all duration-[2s] grayscale-[0.3] group-hover:grayscale-0"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </div>

              <!-- Content -->
              <div class="w-full lg:w-1/2 space-y-8">
                <div class="space-y-4">
                  <div class="h-1 w-12 bg-brand-accent/20 group-hover:w-24 group-hover:bg-brand-accent transition-all duration-700"></div>
                  <h2 class="font-serif text-3xl lg:text-4xl font-bold text-brand-blue leading-[1.1] tracking-tighter uppercase">
                     {service.category}
                  </h2>
                </div>

                <p class="text-slate-600 text-lg leading-relaxed font-medium border-l-4 border-brand-accent/10 pl-10 max-w-xl">
                  {service.shortSummary}
                </p>

                <div class="grid grid-cols-1 gap-4 pt-4">
                   {service.items.slice(0, 4).map(item => (
                     <div class="flex items-start gap-4 group/li">
                        <div class="mt-2 shrink-0 w-2 h-2 rounded-full bg-slate-300 group-hover/li:bg-brand-accent transition-all duration-300"></div>
                        <span class="text-sm md:text-base font-medium text-slate-700 leading-relaxed group-hover/li:text-brand-blue transition-colors duration-300">
                          {typeof item === 'string' ? item : item.title}
                        </span>
                     </div>
                   ))}
                </div>

                <div class="pt-6">
                  <a 
                    href={`/services/${service.slug}`} 
                    class="group/cta inline-flex items-center gap-10 bg-brand-blue text-white px-10 py-5 rounded-full hover:bg-brand-accent transition-all duration-500 shadow-xl"
                  >
                    <span class="font-black tracking-[0.4em] text-[10px] uppercase text-white">View Details</span>
                    <svg class="w-5 h-5 transform group-hover/cta:translate-x-3 transition-transform text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </a>
                </div>
              </div>

            </div>
          )
        })}
      </div>

    </div>
  </section>

  <style>
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script>
    // Active Navigation Highlighting
    const navLinks = document.querySelectorAll('[data-service-nav]');
    const sections = document.querySelectorAll('.animate-on-scroll[id]');
    const navContainer = document.getElementById('nav-scroll-container');
    const scrollLeftBtn = document.getElementById('scroll-left');
    const scrollRightBtn = document.getElementById('scroll-right');

    const handleOverflow = () => {
      if (!navContainer) return;
      const isOverflowing = navContainer.scrollWidth > navContainer.clientWidth;
      if (isOverflowing) {
        navContainer.classList.remove('justify-center');
        navContainer.classList.add('justify-start');
      } else {
        navContainer.classList.add('justify-center');
        navContainer.classList.remove('justify-start');
      }
    };

    const updateArrows = () => {
      if (!navContainer || !scrollLeftBtn || !scrollRightBtn) return;
      
      const scrollLeft = navContainer.scrollLeft;
      const maxScroll = navContainer.scrollWidth - navContainer.clientWidth;
      
      // Toggle Left Arrow
      if (scrollLeft <= 10) {
        scrollLeftBtn.classList.add('opacity-0', 'pointer-events-none');
        scrollLeftBtn.classList.remove('opacity-100', 'pointer-events-auto');
      } else {
        scrollLeftBtn.classList.remove('opacity-0', 'pointer-events-none');
        scrollLeftBtn.classList.add('opacity-100', 'pointer-events-auto');
      }
      
      // Toggle Right Arrow
      if (scrollLeft >= maxScroll - 10) {
        scrollRightBtn.classList.add('opacity-0', 'pointer-events-none');
        scrollRightBtn.classList.remove('opacity-100', 'pointer-events-auto');
      } else {
        scrollRightBtn.classList.remove('opacity-0', 'pointer-events-none');
        scrollRightBtn.classList.add('opacity-100', 'pointer-events-auto');
      }
    };

    // Scroll Handlers
    scrollLeftBtn?.addEventListener('click', () => {
      navContainer?.scrollBy({ left: -400, behavior: 'smooth' });
    });

    scrollRightBtn?.addEventListener('click', () => {
      navContainer?.scrollBy({ left: 400, behavior: 'smooth' });
    });

    navContainer?.addEventListener('scroll', updateArrows);
    window.addEventListener('resize', () => {
      handleOverflow();
      updateArrows();
    });
    
    // Initial setup
    handleOverflow();
    updateArrows(); 

    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -70% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          navLinks.forEach(link => {
            if (link.getAttribute('href') === `#${id}`) {
              link.classList.add('text-brand-accent', 'active');
              link.classList.remove('text-slate-400');
              link.querySelector('span')?.classList.add('bg-brand-accent');
              link.querySelector('span')?.classList.remove('bg-slate-200');
              
              // Scroll the active link into view in the horizontal nav
              if (navContainer) {
                const linkRect = link.getBoundingClientRect();
                const containerRect = navContainer.getBoundingClientRect();
                const scrollLeft = linkRect.left - containerRect.left + navContainer.scrollLeft - (containerRect.width / 2) + (linkRect.width / 2);
                navContainer.scrollTo({ left: scrollLeft, behavior: 'smooth' });
              }
            } else {
              link.classList.remove('text-brand-accent', 'active');
              link.classList.add('text-slate-400');
              link.querySelector('span')?.classList.remove('bg-brand-accent');
              link.querySelector('span')?.classList.add('bg-slate-200');
            }
          });
        }
      });
    }, observerOptions);

    sections.forEach(section => observer.observe(section));
  </script>

</BaseLayout>
