---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { SITE_DATA } from '../constants/siteData';
---

<BaseLayout title="About Us">
  <Hero 
    title="About Our Firm" 
    subtitle="Learn more about our mission, vision, and the team driving your corporate success." 
    image={SITE_DATA.images.aboutHero}
    isMain={false}
  />

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-16">
        
        <!-- Left Col: Overview & Highlights -->
        <div class="lg:w-2/3">
          <div class="mb-12 animate-on-scroll">
            <h2 class="font-serif text-3xl font-bold text-brand-blue mb-6">Who We Are</h2>
            <div class="prose prose-lg text-slate-600 prose-a:text-brand-accent max-w-none">
              <p class="leading-relaxed whitespace-pre-line">{SITE_DATA.about.overview}</p>
            </div>
          </div>

          <div class="animate-on-scroll stagger-1">
            <h3 class="font-serif text-2xl font-bold text-brand-blue mb-6">Firm Highlights</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {SITE_DATA.about.highlights.map(highlight => (
                <div class="bg-brand-light p-4 rounded-lg flex items-start border border-slate-100 hover:border-brand-accent/30 transition-colors">
                  <svg class="w-6 h-6 text-brand-accent mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <span class="text-slate-700 text-sm font-medium">{highlight}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Right Col: Presence -->
        <div class="lg:w-1/3">
          <div class="bg-brand-blue rounded-xl p-8 text-white shadow-2xl animate-on-scroll stagger-2 sticky top-32">
            <h3 class="font-serif text-2xl font-bold mb-6 text-transparent bg-clip-text bg-gradient-to-r from-brand-accent to-yellow-400">Our Presence</h3>
            <ul class="space-y-6">
              {SITE_DATA.about.presence.map((loc, index) => (
                <li class="flex items-center">
                  <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center mr-4 shrink-0 border border-white/20">
                    <span class="font-bold text-brand-accent">{index + 1}</span>
                  </div>
                  <span class="text-lg font-medium tracking-wide">{loc}</span>
                </li>
              ))}
            </ul>
            <div class="mt-10 pt-8 border-t border-white/20">
              <p class="text-slate-300 italic text-sm">Providing seamless services across major corporate hubs in India.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-24 bg-brand-light border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
        <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl font-bold text-brand-blue mb-6">Meet Our Leadership</h2>
        <p class="text-slate-600 text-lg">Our team of experienced Company Secretaries and legal professionals.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
        {SITE_DATA.team.map((member, index) => {
          const slug = member.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
          const isGroup = !member.role;
          return (
          <div class={`bg-white rounded-xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 animate-on-scroll stagger-${(index % 4) + 1} flex flex-col`}>
            <div class="aspect-[4/5] overflow-hidden relative group shrink-0 bg-slate-100">
              <!-- Using dynamic image from site_data -->
              <img 
                src={member.image} 
                alt={member.name} 
                class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-110 grayscale group-hover:grayscale-0"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-blue/90 via-transparent to-transparent opacity-80"></div>
              {!isGroup && (
                <div class="absolute bottom-4 left-4 right-4">
                  <span class="bg-brand-accent text-white text-xs font-bold px-2 py-1 rounded inline-block mb-2">{member.role}</span>
                </div>
              )}
            </div>
            
            <div class="p-6 flex flex-col flex-grow">
              <h3 class="text-xl font-bold text-brand-blue mb-1">{member.name}</h3>
              {member.qualification && <p class="text-sm font-semibold text-slate-500 mb-4">{member.qualification}</p>}
              <p class="text-slate-600 text-sm leading-relaxed line-clamp-3 mb-4">{member.description}</p>
              
              <div class="mt-auto pt-4 border-t border-slate-100">
                <a href={`/team/${slug}`} class="inline-flex items-center text-brand-accent font-semibold hover:text-brand-blue transition-colors">
                  Read Full Profile
                  <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              </div>
            </div>
          </div>
        )})}
      </div>
    </div>
  </section>

</BaseLayout>
