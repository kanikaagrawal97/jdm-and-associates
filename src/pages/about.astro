---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { SITE_DATA } from '../constants/siteData';
---

<BaseLayout 
  title="About Us"
  description="Learn about JDM and Associates LLP — our mission, expert leadership team, and national presence across Surat, Mumbai, and Chennai in corporate governance and compliance."
>
  <Hero 
    title="About Us" 
    subtitle="Learn more about our mission, vision, and the team driving your corporate success." 
    image={SITE_DATA.images.aboutHero}
    isMain={false}
  />

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-16">
        
        <!-- Left Col: Overview & Highlights -->
        <div class="lg:w-2/3">
          <div class="mb-12 animate-on-scroll">
            <h2 class="font-serif text-3xl font-bold text-brand-blue mb-6">Who We Are</h2>
            <div class="prose prose-lg text-slate-600 prose-a:text-brand-accent max-w-none">
              <p class="leading-relaxed whitespace-pre-line">{SITE_DATA.about.overview}</p>
            </div>
          </div>
        </div>

        <!-- Right Col: Presence -->
        <div class="lg:w-1/3">
          <div class="bg-brand-blue rounded-xl p-8 text-white shadow-2xl animate-on-scroll stagger-2">
            <h3 class="font-serif text-2xl font-bold mb-6 text-transparent bg-clip-text bg-gradient-to-r from-brand-accent to-yellow-400">Our Presence</h3>
            <ul class="space-y-6">
              {SITE_DATA.about.presence.map((loc, index) => {
                const city = loc.split(/\s*[–-]\s*/).pop().toLowerCase();
                return (
                  <li class="flex items-center">
                    <a href={`/contact#office-${city}`} class="flex items-center group transition-all duration-300 hover:translate-x-2">
                      <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center mr-4 shrink-0 border border-white/20 group-hover:bg-brand-accent group-hover:border-brand-accent transition-all duration-300">
                        <span class="font-bold text-brand-accent group-hover:text-white transition-colors duration-300">{index + 1}</span>
                      </div>
                      <span class="text-lg font-medium tracking-wide group-hover:text-brand-accent transition-colors duration-300">{loc}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
            <div class="mt-10 pt-8 border-t border-white/20">
              <p class="text-slate-300 italic text-sm">Providing seamless services across major corporate hubs in India.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Vision & Mission Section -->
  <section class="py-24 bg-gradient-to-br from-brand-blue via-brand-blue-dark to-[#0E2B4D] relative overflow-hidden">
    <!-- Fine Pattern Grid -->
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- Section Header -->
      <div class="flex flex-col md:flex-row items-end justify-between mb-24 animate-on-scroll">
        <div class="max-w-xl">
          <h2 class="font-serif text-3xl sm:text-4xl font-bold text-white leading-[1.1] tracking-tighter mb-6 uppercase">
            Our <span class="italic font-light text-brand-accent">Vision</span>
            <br> & Mission
          </h2>
          <p class="text-slate-300 text-lg font-medium leading-relaxed italic pr-12">Guiding principles that drive our commitment to excellence.</p>
        </div>
      </div>

      <!-- Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        
        <!-- Vision Card -->
        <div class="group bg-white p-10 rounded-[2rem] md:rounded-[4rem] rounded-tr-none md:rounded-tr-none rounded-bl-none md:rounded-bl-none shadow-sm border border-slate-100/50 hover:shadow-2xl hover:border-brand-accent/30 transition-all duration-700 animate-on-scroll stagger-1">
          
          <div class="flex items-center justify-between mb-8">
            <div class="h-1 w-12 bg-slate-100 group-hover:w-20 group-hover:bg-brand-accent transition-all duration-500"></div>
          </div>

          <!-- Icon -->
          <div class="w-16 h-16 rounded-full bg-brand-blue/5 border border-brand-blue/10 flex items-center justify-center mb-8 group-hover:bg-brand-blue group-hover:border-brand-blue transition-all duration-500">
            <svg class="w-7 h-7 text-brand-blue group-hover:text-white transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>

          <div class="space-y-4">
            <h3 class="font-serif text-2xl font-bold text-brand-blue group-hover:text-brand-accent transition-colors uppercase">
              Our Vision
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed border-l-2 border-brand-accent/10 pl-6 pr-6 italic">
              Coming Soon
            </p>
          </div>
        </div>

        <!-- Mission Card -->
        <div class="group bg-white p-10 rounded-[2rem] md:rounded-[4rem] rounded-tr-none md:rounded-tr-none rounded-bl-none md:rounded-bl-none shadow-sm border border-slate-100/50 hover:shadow-2xl hover:border-brand-accent/30 transition-all duration-700 animate-on-scroll stagger-2">
          
          <div class="flex items-center justify-between mb-8">
            <div class="h-1 w-12 bg-slate-100 group-hover:w-20 group-hover:bg-brand-accent transition-all duration-500"></div>
          </div>

          <!-- Icon -->
          <div class="w-16 h-16 rounded-full bg-brand-blue/5 border border-brand-blue/10 flex items-center justify-center mb-8 group-hover:bg-brand-blue group-hover:border-brand-blue transition-all duration-500">
            <svg class="w-7 h-7 text-brand-blue group-hover:text-white transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0l2.77-.693a9 9 0 016.208.682l.108.054a9 9 0 006.086.71l3.114-.732a48.524 48.524 0 01-.005-10.499l-3.11.732a9 9 0 01-6.085-.711l-.108-.054a9 9 0 00-6.208-.682L3 4.5M3 15V4.5" />
            </svg>
          </div>

          <div class="space-y-4">
            <h3 class="font-serif text-2xl font-bold text-brand-blue group-hover:text-brand-accent transition-colors uppercase">
              Our Mission
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed border-l-2 border-brand-accent/10 pl-6 pr-6 italic">
              Coming Soon
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-24 bg-brand-light border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
        <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl font-bold text-brand-blue mb-6">Meet Our Leadership</h2>
        <p class="text-slate-600 text-lg">Our team of experienced Company Secretaries and legal professionals.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
        {SITE_DATA.team.map((member, index) => {
          const slug = member.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
          const isGroup = !member.role;
          return (
          <div class={`bg-white rounded-xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 animate-on-scroll stagger-${(index % 4) + 1} flex flex-col`}>
            <div class="aspect-[4/5] overflow-hidden relative group shrink-0 bg-slate-100">
              <!-- Using dynamic image from site_data -->
              <img 
                src={member.image} 
                alt={member.name} 
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-110 grayscale group-hover:grayscale-0"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-blue/90 via-transparent to-transparent opacity-80"></div>
              {!isGroup && (
                <div class="absolute bottom-4 left-4 right-4">
                  <span class="bg-brand-accent text-white text-xs font-bold px-2 py-1 rounded inline-block mb-2">{member.role}</span>
                </div>
              )}
            </div>
            
            <div class="p-6 flex flex-col flex-grow">
              <h3 class="text-xl font-bold text-brand-blue mb-1">{member.name}</h3>
              {member.qualification && <p class="text-sm font-semibold text-slate-500 mb-4">{member.qualification}</p>}
              <p class="text-slate-600 text-sm leading-relaxed line-clamp-3 mb-4">{member.description}</p>
              
              <div class="mt-auto pt-4 border-t border-slate-100">
                <a href={`/team/${slug}`} class="inline-flex items-center text-brand-accent font-semibold hover:text-brand-blue transition-colors">
                  Read Full Profile
                  <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              </div>
            </div>
          </div>
        )})}
      </div>
    </div>
  </section>

</BaseLayout>
