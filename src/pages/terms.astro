---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DATA } from '../constants/siteData';

const terms = SITE_DATA.terms;
---

<BaseLayout title="Terms of Service">
  <section class="pt-32 pb-24 bg-brand-light relative overflow-hidden">
    <!-- Background Decor -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-accent/5 rounded-full blur-[100px] -z-10 translate-x-1/3 -translate-y-1/3"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-blue/5 rounded-full blur-[100px] -z-10 -translate-x-1/3 translate-y-1/3"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16 text-center animate-on-scroll">
        <h1 class="text-4xl md:text-6xl font-serif font-bold text-brand-blue mb-6">Terms of Service</h1>
        <p class="text-slate-500 font-medium">Last Updated: March 2026</p>
        <div class="w-20 h-1.5 bg-brand-accent mx-auto mt-8 rounded-full"></div>
      </div>

      <div class="space-y-12 bg-white p-8 md:p-12 rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 animate-on-scroll stagger-1">
        {terms.map((term) => (
          <div class="border-b border-slate-100 last:border-0 pb-8 last:pb-0">
            <h2 class="text-2xl font-serif font-bold text-brand-blue mb-4">{term.title}</h2>
            <div class="prose prose-slate max-w-none text-slate-600 leading-relaxed whitespace-pre-line">
              {term.content}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 p-8 bg-brand-accent/10 border border-brand-accent/20 rounded-3xl text-center animate-on-scroll stagger-2">
        <h3 class="text-xl font-serif font-bold text-brand-blue mb-4">Agreement to Terms</h3>
        <p class="text-slate-600 mb-8 max-w-md mx-auto small italic">Your engagement with our firm is subject to these professional terms and standard engagement letters.</p>
        <a href="/contact" class="inline-flex items-center px-8 py-4 bg-brand-blue text-white font-bold rounded-full hover:bg-brand-accent transition-all duration-300 shadow-lg">
          Talk to Us
          <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
