---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { SITE_DATA } from '../constants/siteData';
---

<BaseLayout 
  title="Insights"
  description="Stay updated with the latest regulatory updates, compliance insights, corporate governance articles, and industry analysis from JDM and Associates LLP."
>
  <Hero 
    title="Insights" 
    subtitle="Expert perspectives on corporate governance, regulatory updates, and compliance best practices." 
    image={SITE_DATA.images.aboutHero}
    isMain={false}
  />

  <!-- Insights Content Section -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Coming Soon State -->
      <div class="flex flex-col items-center justify-center py-20 animate-on-scroll stagger-1">
        <div class="w-24 h-24 rounded-full bg-brand-blue/5 border-2 border-dashed border-brand-blue/20 flex items-center justify-center mb-8">
          <svg class="w-10 h-10 text-brand-blue/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <h3 class="font-serif text-2xl font-bold text-brand-blue mb-3">Coming Soon</h3>
      </div>

    </div>
  </section>
</BaseLayout>
