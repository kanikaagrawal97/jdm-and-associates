---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DATA } from '../../constants/siteData';

export function getStaticPaths() {
  return SITE_DATA.team.map(member => {
    const slug = member.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    return {
      params: { slug },
      props: { member, index: SITE_DATA.team.indexOf(member) }
    };
  });
}

const { slug } = Astro.params;
const member = SITE_DATA.team.find(m => m.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') === slug);

if (!member) {
  return Astro.redirect('/404');
}

const isGroup = !member.role;
const memberDescription = member.description 
  ? `${member.description.split('.')[0].trim()}.` 
  : `${member.name} is a member of the JDM and Associates LLP team.`;
const cleanMembership = member.membership?.trim().replace(/-\s*$/, '').trim() || null;
---
<BaseLayout 
  title={member.name}
  description={`${member.name}${member.role ? `, ${member.role}` : ''} at JDM and Associates LLP. ${memberDescription}`}
  image={member.image || '/images/hero-bg.png'}
  type="profile"
>
  <!-- Top Navigation (Desktop) -->
  <div class="bg-white/80 backdrop-blur-md border-b border-slate-100 sticky top-20 z-30 py-4 hidden md:block">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
      <a href="/about" class="group flex items-center text-slate-500 hover:text-brand-accent transition-all duration-300">
        <div class="w-8 h-8 rounded-full border border-slate-200 flex items-center justify-center mr-3 group-hover:border-brand-accent/30 group-hover:bg-brand-accent/5">
          <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        </div>
        <span class="text-sm font-medium">Back to Leadership Team</span>
      </a>
      <div class="flex items-center space-x-4">
        <span class="h-1 w-8 bg-brand-accent opacity-20"></span>
        <span class="text-xs uppercase tracking-widest font-bold text-slate-400">Team Profile</span>
      </div>
    </div>
  </div>

  <section class="relative pt-12 pb-24 overflow-hidden bg-brand-light">
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-96 h-96 bg-brand-accent/5 rounded-full blur-3xl -z-10"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-[32rem] h-[32rem] bg-brand-blue/5 rounded-full blur-[100px] -z-10"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Mobile Back Button -->
      <div class="mb-10 md:hidden animate-on-scroll">
        <a href="/about" class="inline-flex items-center text-brand-accent font-semibold transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          Back
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
        <!-- Left Column: Photo & Brief Info -->
        <div class="lg:col-span-5 animate-on-scroll">
          <div class="lg:sticky lg:top-40">
            <div class="relative group">
              <!-- Image Frame -->
              <div class="absolute -inset-4 bg-gradient-to-tr from-brand-accent/20 to-transparent rounded-[2.5rem] -z-10 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
              
              <div class="aspect-[4/5] max-h-[600px] rounded-[2rem] overflow-hidden shadow-2xl border-4 border-white bg-slate-100 relative mx-auto lg:mx-0 max-w-md lg:max-w-none">
                <img 
                  src={member.image || "/images/member-placeholder.png"} 
                  alt={member.name} 
                  fetchpriority="high"
                  loading="eager"
                  decoding="async"
                  class="w-full h-full object-cover object-top transition-all duration-1000 group-hover:scale-105"
                />
                
                <!-- Overlay Gradient -->
                <div class="absolute inset-0 bg-gradient-to-t from-brand-blue/60 via-transparent to-transparent opacity-60"></div>
              </div>

              <!-- Floating Credentials Badge -->
              {(member.qualification || cleanMembership) && (
                <div class="mt-8 lg:mt-0 lg:absolute lg:bottom-6 lg:left-6 lg:right-6 p-5 bg-slate-900 lg:bg-slate-900/80 lg:backdrop-blur-xl rounded-2xl border border-slate-800 lg:border-white/10 text-white shadow-xl lg:shadow-2xl transition-all duration-500 relative z-20 mx-auto lg:mx-0 max-w-md lg:max-w-none">
                  <div class="flex flex-col sm:flex-row sm:items-center gap-6 sm:gap-8 overflow-hidden">
                    {member.qualification && (
                      <div class="flex items-center gap-3 min-w-0">
                        <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/10">
                          <svg class="w-5 h-5 text-brand-accent/90" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /></svg>
                        </div>
                        <div class="min-w-0">
                          <p class="text-[9px] uppercase tracking-[0.2em] font-bold text-slate-400 mb-0.5">Education</p>
                          <p class="font-bold text-xs leading-tight truncate">{member.qualification}</p>
                        </div>
                      </div>
                    )}
                    
                    {cleanMembership && (
                      <div class="flex items-center gap-3 min-w-0">
                        <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/10">
                          <svg class="w-5 h-5 text-brand-accent/90" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                        </div>
                        <div class="min-w-0">
                          <p class="text-[9px] uppercase tracking-[0.2em] font-bold text-slate-400 mb-0.5">Membership No.</p>
                          <p class="font-bold text-xs leading-tight truncate">{cleanMembership}</p>
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              )}
            </div>

          </div>
        </div>

        <!-- Right Column: Biography & Details -->
        <div class="lg:col-span-7 animate-on-scroll stagger-1">
          <div class="mb-12">
            {!isGroup && (
              <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-brand-accent/10 border border-brand-accent/20 mb-6">
                <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse mr-2"></span>
                <span class="text-brand-accent text-xs font-bold uppercase tracking-[0.2em]">{member.role}</span>
              </div>
            )}
            <h1 class="font-serif text-3xl sm:text-4xl md:text-6xl font-bold text-brand-blue mb-6 leading-tight tracking-tight">
              {member.name}
            </h1>
            
          </div>

          <div class="relative">
            <!-- Decorative Large Initial or Icon -->
            <div class="absolute -top-12 -left-8 text-slate-100/60 -z-10 select-none">
              <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21L14.017 18C14.017 16.899 14.899 16.017 16 16.017L19 16.017C19.552 16.017 20 15.569 20 15.017L20 9.017C20 8.465 19.552 8.017 19 8.017L15 8.017C14.448 8.017 14 7.569 14 7.017L14 5.017C14 4.465 14.448 4.017 15 4.017L20 4.017C21.105 4.017 22 4.912 22 6.017L22 15.017C22 17.656 20.156 19.863 17.616 20.463L14.017 21ZM2.017 21L2.017 18C2.017 16.899 2.899 16.017 4 16.017L7 16.017C7.552 16.017 8 15.569 8 15.017L8 9.017C8 8.465 7.552 8.017 7 8.017L3 8.017C2.448 8.017 2 7.569 2 7.017L2 5.017C2 4.465 2.448 4.017 3 4.017L8 4.017C9.105 4.017 10 4.912 10 6.017L10 15.017C10 17.656 8.156 19.863 5.616 20.463L2.017 21Z" /></svg>
            </div>
            
            <div class="space-y-8">
              <div class="prose prose-lg sm:prose-xl prose-slate max-w-none text-slate-700 leading-[1.8] whitespace-pre-line prose-p:mb-8">
                {member.description}
              </div>
            </div>
            

          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

