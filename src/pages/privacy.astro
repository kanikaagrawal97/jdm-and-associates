---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DATA } from '../constants/siteData';

const policies = [
  {
    title: "Introduction",
    content: `JDM and Associates LLP ("we," "us," or "our") is committed to protecting your privacy. This Privacy Policy explains how we collect, use, and safeguard your personal information when you visit our website or engage our services as Corporate Governance & Compliance Consultants.`
  },
  {
    title: "Information We Collect",
    content: "We may collect personal information such as your name, email address, phone number, and professional details when you fill out contact forms, subscribe to our newsletters, or engage in professional consultations. We also collect non-personal data through cookies to improve website performance."
  },
  {
    title: "How We Use Your Information",
    content: `Your information is used to:
    - Provide and manage our professional services.
    - Respond to inquiries and provide customer support.
    - Send relevant regulatory updates and newsletters.
    - Comply with legal and statutory requirements under the Companies Act and other applicable laws.`
  },
  {
    title: "Data Security",
    content: "We implement robust technical and organizational measures to protect your data against unauthorized access, loss, or misuse. Our systems are equipped with advanced compliance software to ensure data integrity."
  },
  {
    title: "Third-Party Disclosure",
    content: "We do not sell or trade your personal information. We may share data with trusted third-party service providers who assist us in operating our website or conducting our business, provided they agree to keep this information confidential."
  },
  {
    title: "Your Rights",
    content: "You have the right to access, correct, or request the deletion of your personal information held by us. To exercise these rights, please contact our compliance officer at the details provided below."
  },
  {
    title: "Changes to This Policy",
    content: "We may update this Privacy Policy from time to time to reflect changes in our practices or regulatory requirements. We encourage you to review this page periodically."
  }
];
---

<BaseLayout title="Privacy Policy">
  <section class="pt-32 pb-24 bg-brand-light relative overflow-hidden">
    <!-- Background Decor -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-accent/5 rounded-full blur-[100px] -z-10 translate-x-1/3 -translate-y-1/3"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-blue/5 rounded-full blur-[100px] -z-10 -translate-x-1/3 translate-y-1/3"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16 text-center animate-on-scroll">
        <h1 class="text-4xl md:text-6xl font-serif font-bold text-brand-blue mb-6">Privacy Policy</h1>
        <p class="text-slate-500 font-medium">Last Updated: March 2026</p>
        <div class="w-20 h-1.5 bg-brand-accent mx-auto mt-8 rounded-full"></div>
      </div>

      <div class="space-y-12 bg-white p-8 md:p-12 rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 animate-on-scroll stagger-1">
        {policies.map((policy) => (
          <div class="border-b border-slate-100 last:border-0 pb-8 last:pb-0">
            <h2 class="text-2xl font-serif font-bold text-brand-blue mb-4">{policy.title}</h2>
            <div class="prose prose-slate max-w-none text-slate-600 leading-relaxed whitespace-pre-line">
              {policy.content}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 p-8 bg-brand-blue rounded-3xl text-white text-center animate-on-scroll stagger-2">
        <h3 class="text-xl font-serif font-bold mb-4">Questions about our Privacy Policy?</h3>
        <p class="text-slate-300 mb-8 max-w-md mx-auto small">If you have any questions, please reach out to us directly.</p>
        <a href="/contact" class="inline-flex items-center px-8 py-4 bg-brand-accent text-white font-bold rounded-full hover:bg-white hover:text-brand-blue transition-all duration-300 shadow-lg">
          Contact Us
          <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
