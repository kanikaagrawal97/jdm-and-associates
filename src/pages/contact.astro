---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE_DATA } from '../constants/siteData';

const headOffice = SITE_DATA.contact.offices[0];
---

<BaseLayout 
  title="Contact Us"
  description="Get in touch with JDM and Associates LLP. Reach our corporate governance experts in Surat, Mumbai, and Chennai for professional compliance and secretarial advisory services."
>
  <Hero 
    title="Get in Touch" 
    subtitle="Connect with our experts across Surat, Mumbai, and Chennai for professional corporate advisory services." 
    image="https://images.unsplash.com/photo-1497366216548-37526070297c?ixlib=rb-1.2.1&auto=format&fit=crop&w=1280&q=60"
    isMain={false}
    showSocials={true}
  />

  <section class="pt-24 bg-brand-light relative z-10 -mt-12 lg:-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <!-- Value Proposition -->
        <div class="animate-on-scroll h-full">
          <div class="bg-brand-blue text-white p-10 md:p-12 rounded-2xl shadow-xl h-full flex flex-col justify-center">
            <h2 class="font-serif text-3xl md:text-4xl font-bold mb-6">Let's Discuss Your Needs</h2>
            <p class="text-white/80 text-lg mb-10 leading-relaxed">
              Whether you're a startup looking for guidance, seeking compliance management, or an established corporate needing complex restructuring, our team is here to help. Reach out to us for expert advisory services.
            </p>
            
            <div class="space-y-8">
              <div class="flex items-start">
                <div class="bg-white/10 p-3.5 rounded-xl mr-5 shrink-0 border border-white/5">
                  <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold mb-2">Quick Response Time</h3>
                  <p class="text-white/70 leading-relaxed">We respect your time and aim to respond to all inquiries within 24 business hours.</p>
                </div>
              </div>

              <div class="flex items-start">
                <div class="bg-white/10 p-3.5 rounded-xl mr-5 shrink-0 border border-white/5">
                  <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold mb-2">Expert Consultation</h3>
                  <p class="text-white/70 leading-relaxed">Get direct access to our highly qualified and experienced Company Secretaries.</p>
                </div>
              </div>

              <div class="flex items-start">
                <div class="bg-white/10 p-3.5 rounded-xl mr-5 shrink-0 border border-white/5">
                  <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div>
                  <h3 class="text-xl font-bold mb-2">National Presence</h3>
                  <p class="text-white/70 leading-relaxed">Serving clients seamlessly across geographies through offices in Surat, Mumbai, and Chennai.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="animate-on-scroll stagger-1 h-full">
          <ContactForm />
        </div>

      </div>
    </div>
  </section>

  <!-- Locations Maps Section - Minimalist & Map-First -->
  <section id="contact-locations" class="py-32 bg-brand-light relative overflow-hidden scroll-mt-20">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-brand-blue/[0.02] -skew-x-12 transform origin-top"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="text-4xl md:text-5xl font-serif font-bold text-brand-blue mb-4">Our Presence</h2>
        <div class="w-16 h-1 bg-brand-accent mx-auto rounded-full"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {SITE_DATA.contact.offices.map((office, index) => (
          <div id={`office-${office.city.toLowerCase()}`} class={`flex flex-col h-full group animate-on-scroll stagger-${index + 1} scroll-mt-50`}>
            <div class="relative flex-grow min-h-[450px] w-full bg-white rounded-[2.5rem] overflow-hidden shadow-[0_20px_50px_rgba(27,80,145,0.08)] border border-brand-blue/5 flex flex-col">
              
              <!-- Map Container - Takes full height -->
              <div class="absolute inset-0 z-0">
                <iframe 
                  src={office.mapEmbedUrl}
                  width="100%" 
                  height="100%" 
                  style="border:0;" 
                  allowfullscreen="" 
                  loading="lazy" 
                  referrerpolicy="no-referrer-when-downgrade"
                  title={`${office.branch} Office Location`}
                  class="w-full h-full grayscale-[0.2] contrast-[1.1] transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-105"
                ></iframe>
                <!-- Subtle overlay to make labels pop -->
                <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-black/20 to-transparent pointer-events-none"></div>
              </div>

              <!-- Floating Labels -->
              <div class="relative z-10 p-6 flex justify-between items-start pointer-events-none">
                <div class="glass px-5 py-2.5 rounded-2xl border border-white/40 shadow-xl pointer-events-auto">
                  <h3 class="text-lg font-bold text-brand-blue tracking-tight">{office.city}</h3>
                </div>
                
                <div class={`px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-[0.1em] shadow-lg pointer-events-auto ${index === 0 ? 'bg-brand-accent text-white' : 'bg-brand-blue text-white'}`}>
                  {index === 0 ? "Head Office" : "Branch"}
                </div>
              </div>

              <!-- Content and Action - Pushed to bottom -->
              <div class="relative z-10 mt-auto p-6 pointer-events-none">
                <div class="glass p-5 rounded-3xl border border-white/60 shadow-2xl translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 pointer-events-auto">
                  <p class="text-xs text-brand-blue/70 font-medium mb-4 line-clamp-2">{office.address}</p>
                  <a 
                    href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(office.address)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center gap-2 w-full py-3 bg-brand-blue hover:bg-brand-accent text-white text-sm font-bold rounded-xl transition-all duration-300 group/btn shadow-lg shadow-brand-blue/20"
                  >
                    <span>Get Directions</span>
                    <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                  </a>
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
