---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: string;
}

const { 
	title, 
	description = "JDM and Associates LLP is a peer-reviewed corporate service firm specialising in Corporate Laws, Secretarial Compliances, FEMA, XBRL, Secretarial Audits, IPO Due Diligence, and more. Offices in Surat, Mumbai, and Chennai.",
	image = "/images/hero-bg.png",
	type = "website"
} = Astro.props;

const siteUrl = "https://www.csjdm.com";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(image, siteUrl);
const pageTitle = title === "Home" ? "JDM and Associates LLP | Corporate Governance & Compliance Consultants" : `${title} | JDM and Associates LLP`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary SEO -->
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="company secretary, corporate governance, compliance, FEMA, XBRL, secretarial audit, IPO, Surat, Mumbai, Chennai, JDM Associates" />
		<meta name="author" content="JDM and Associates LLP" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="JDM and Associates LLP" />
		<meta property="og:locale" content="en_IN" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />

		<!-- Favicons -->
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Cormorant+Garamond:wght@400;500;600;700&display=swap" rel="stylesheet" />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "LegalService",
			"name": "JDM and Associates LLP",
			"image": ogImageURL,
			"@id": siteUrl,
			"url": siteUrl,
			"telephone": "+91 9510827803",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "101-B, Zenon, Opp, Unique Hospital, B/s. New Opera House, Bamroli Road",
				"addressLocality": "Surat",
				"addressRegion": "GJ",
				"postalCode": "395002",
				"addressCountry": "IN"
			},
			"description": "JDM and Associates LLP is a peer-reviewed corporate service firm specialising in Corporate Laws, Secretarial Compliances, FEMA, XBRL, Secretarial Audits, IPO Due Diligence, and more.",
			"sameAs": [
				"https://www.linkedin.com/company/jdm-and-associates-llp"
			]
		})}></script>

		<ClientRouter />
	</head>
	<body class="flex flex-col min-h-screen bg-brand-light">

		<Navbar />
		

		<!-- Global Toast Container -->
		<div id="toast-container"></div>
		
		<main class="flex-grow pt-20"> <!-- pt-20 to account for fixed navbar -->
			<slot />
		</main>

		<Footer />

		<!-- Scroll to Top Button -->
		<button id="scrollToTopBtn" class="fixed bottom-6 right-6 md:bottom-10 md:right-10 bg-brand-accent text-white p-3.5 rounded-full shadow-[0_4px_14px_0_rgba(200,155,60,0.39)] opacity-0 pointer-events-none translate-y-4 transition-all duration-500 z-50 hover:bg-brand-blue hover:scale-110 focus:outline-none ring-2 ring-transparent group" aria-label="Scroll to top">
			<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transform transition-transform group-hover:-translate-y-1"><path d="m18 15-6-6-6 6"/></svg>
		</button>

		<!-- Intersection Observer for Scroll Animations & Progress -->
		<script>
			// Force scroll to top on refresh
			if (window.history && 'scrollRestoration' in history) {
				history.scrollRestoration = 'manual';
			}
			window.scrollTo(0, 0);

			function initAnimations() {

				const observerOptions = {
					root: null,
					rootMargin: '0px',
					threshold: 0
				};

				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
							
							// Handle Stats Counter
							if (entry.target.classList.contains('count-up')) {
								const target = parseInt(entry.target.getAttribute('data-count') || '0');
								let count = 0;
								const duration = 2000;
								const startTime = performance.now();
								
								const animate = (currentTime: number) => {
									const elapsed = currentTime - startTime;
									const progress = Math.min(elapsed / duration, 1);
									const currentCount = Math.floor(progress * target);
									entry.target.textContent = currentCount.toString();
									
									if (progress < 1) {
										requestAnimationFrame(animate);
									} else {
										entry.target.textContent = target.toString() + (entry.target.getAttribute('data-suffix') || '');
									}
								};
								requestAnimationFrame(animate);
							}
						}
					});
				}, observerOptions);

				const elements = document.querySelectorAll('.animate-on-scroll, .count-up');
				elements.forEach(el => observer.observe(el));

				// Scroll to Top Logic
				const scrollToTopBtn = document.getElementById('scrollToTopBtn');
				if (scrollToTopBtn) {
					scrollToTopBtn.addEventListener('click', () => {
						window.scrollTo({ top: 0, behavior: 'smooth' });
					});
				}

				const handleScrollToTopVisibility = () => {
					const btn = document.getElementById('scrollToTopBtn');
					if (!btn) return;
					if (window.scrollY > 400) {
						btn.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
						btn.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
					} else {
						btn.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
						btn.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
					}
				};

				// Global Parallax and Scroll Handler
				let ticking = false;
				const handleGlobalScroll = () => {
					handleScrollToTopVisibility();

					if (window.innerWidth >= 1024) { // Only for parallax on tablets/desktops
						const parallaxImages = document.querySelectorAll('.parallax-image');
						parallaxImages.forEach((img: any) => {
							const rect = img.getBoundingClientRect();
							if (rect.top < window.innerHeight && rect.bottom > 0) {
								const speed = 0.06;
								const yPos = -(rect.top * speed);
								img.style.transform = `translate3d(0, ${yPos}px, 0) scale(1.1)`;
							}
						});
					}
					ticking = false;
				};

				// To avoid duplicate listeners on view transition, we can use a small trick:
				if (!(window as any).__scrollListenerAdded) {
					window.addEventListener('scroll', () => {
						if (!ticking) {
							window.requestAnimationFrame(handleGlobalScroll);
							ticking = true;
						}
					});
					(window as any).__scrollListenerAdded = true;
				}
				
				// Ensure correct visibility on page load/transition
				handleScrollToTopVisibility();

				// Magnetic Buttons Effect
				const magneticButtons = document.querySelectorAll('.magnetic-btn');
				magneticButtons.forEach((btn: any) => {
					btn.addEventListener('mousemove', (e: MouseEvent) => {
						if (window.innerWidth < 1024) return; // Disable magnetic effect on mobile
						const rect = btn.getBoundingClientRect();
						const x = e.clientX - rect.left - rect.width / 2;
						const y = e.clientY - rect.top - rect.height / 2;
						
						btn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
						const text = btn.querySelector('span') || btn;
						if (text) text.style.transform = `translate(${x * 0.1}px, ${y * 0.1}px)`;
					});
					
					btn.addEventListener('mouseleave', () => {
						btn.style.transform = '';
						const text = btn.querySelector('span') || btn;
						if (text) text.style.transform = '';
					});
				});
			}

			// Initialize on load and after view transitions
			initAnimations();
			document.addEventListener('astro:after-swap', initAnimations);
		</script>
	</body>
</html>
